{
  "family": "praise-project",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::068645775727:role/praise-project-execution-role",
  "taskRoleArn": "arn:aws:iam::068645775727:role/praise-project-task-role",
  "containerDefinitions": [
    {
      "name": "praise-project",
      "image": "068645775727.dkr.ecr.ap-southeast-1.amazonaws.com/praise-project:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "RAILS_ENV",              "value": "production" },
        { "name": "SOLID_QUEUE_IN_PUMA",    "value": "true" },
        { "name": "RAILS_LOG_LEVEL",        "value": "info" },
        { "name": "AWS_REGION",             "value": "ap-southeast-1" },
        { "name": "HTTP_PORT",              "value": "3000" },
        { "name": "TARGET_PORT",            "value": "3001" }
      ],
      "secrets": [
        {
          "name": "RAILS_MASTER_KEY",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:068645775727:parameter/praise-project/RAILS_MASTER_KEY"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:068645775727:parameter/praise-project/DATABASE_URL"
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:068645775727:parameter/praise-project/ANTHROPIC_API_KEY"
        },
        {
          "name": "APP_HOST",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:068645775727:parameter/praise-project/APP_HOST"
        },
        {
          "name": "S3_BUCKET",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:068645775727:parameter/praise-project/S3_BUCKET"
        },
        {
          "name": "UNSPLASH_ACCESS_KEY",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:068645775727:parameter/praise-project/UNSPLASH_ACCESS_KEY"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/praise-project",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3000/up || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 5,
        "startPeriod": 120
      }
    }
  ]
}
