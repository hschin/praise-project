<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Praise Project" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Praise Project">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="robots" content="noindex, nofollow">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,700;1,6..72,400&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-surface text-on-surface font-body">
    <% unless devise_controller? %>
      <header class="bg-surface/80 backdrop-blur-xl flex justify-between items-center w-full px-4 md:px-8 h-16 sticky top-0 z-50 shadow-ambient"
              data-controller="mobile-menu">
        <div class="flex items-center gap-4 md:gap-6 flex-1">
          <%= link_to root_path, class: "text-xl md:text-2xl font-headline italic text-on-surface hover:opacity-80 transition-opacity" do %>
            Praise Project
          <% end %>
          
          <%# Desktop nav %>
          <nav class="hidden md:flex gap-6">
            <%= link_to t("nav.decks"), root_path, class: "font-medium transition-colors duration-200 #{request.path.start_with?('/decks') || request.path == '/' ? 'text-primary border-b-2 border-primary pb-0.5' : 'text-on-surface-variant hover:text-primary'}" %>
            <%= link_to t("nav.songs"), songs_path, class: "font-medium transition-colors duration-200 #{request.path.start_with?('/songs') ? 'text-primary border-b-2 border-primary pb-0.5' : 'text-on-surface-variant hover:text-primary'}" %>
            <% if current_user.admin? %>
              <%= link_to t("nav.admin"), admin_path, class: "font-medium transition-colors duration-200 #{request.path == '/admin' ? 'text-primary border-b-2 border-primary pb-0.5' : 'text-on-surface-variant hover:text-primary'}" %>
            <% end %>
          </nav>
        </div>

        <%# Desktop actions %>
        <div class="hidden md:flex items-center gap-4">
          <%# Locale toggle %>
          <div class="flex items-center gap-1 bg-surface-container rounded-lg p-0.5 text-xs font-medium font-label">
            <%= button_to "EN", locale_path(locale: :en), method: :patch,
                  class: "px-2.5 py-1 rounded-md transition-all cursor-pointer border-0 #{I18n.locale == :en ? 'bg-surface text-on-surface shadow-sm' : 'text-on-surface-variant hover:text-on-surface bg-transparent'}" %>
            <%= button_to "中文", locale_path(locale: :"zh-CN"), method: :patch,
                  class: "px-2.5 py-1 rounded-md transition-all cursor-pointer border-0 #{I18n.locale == :"zh-CN" ? 'bg-surface text-on-surface shadow-sm' : 'text-on-surface-variant hover:text-on-surface bg-transparent'}" %>
          </div>
          <%= button_to t("nav.new_deck"), quick_create_decks_path, method: :post,
                class: "bg-gradient-to-r from-primary to-primary-container text-on-primary px-5 py-2 rounded-xl font-medium hover:opacity-90 transition-all active:scale-95 duration-150 cursor-pointer" %>
          <span class="text-sm text-on-surface-variant"><%= current_user.email %></span>
          <%= link_to t("nav.logout"), destroy_user_session_path, data: { turbo_method: :delete },
                class: "text-on-surface-variant font-medium hover:text-primary transition-colors" %>
        </div>
        
        <%# Mobile menu button %>
        <button type="button"
                data-action="click->mobile-menu#toggle"
                class="md:hidden p-2 text-on-surface-variant hover:text-primary transition-colors">
          <span class="material-symbols-outlined text-[28px]">menu</span>
        </button>
        
        <%# Mobile menu %>
        <div data-mobile-menu-target="menu"
             class="hidden absolute top-16 left-0 right-0 bg-surface/95 backdrop-blur-xl shadow-lg border-t border-outline-variant/20">
          <nav class="flex flex-col p-4 gap-1">
            <%= link_to root_path,
                  data: { action: "click->mobile-menu#close" },
                  class: "flex items-center gap-3 px-4 py-3 rounded-lg font-medium transition-colors #{request.path.start_with?('/decks') || request.path == '/' ? 'bg-primary/10 text-primary' : 'text-on-surface hover:bg-surface-container-low'}" do %>
              <span class="material-symbols-outlined text-[20px]">dashboard</span>
              <%= t("nav.decks") %>
            <% end %>
            <%= link_to songs_path,
                  data: { action: "click->mobile-menu#close" },
                  class: "flex items-center gap-3 px-4 py-3 rounded-lg font-medium transition-colors #{request.path.start_with?('/songs') ? 'bg-primary/10 text-primary' : 'text-on-surface hover:bg-surface-container-low'}" do %>
              <span class="material-symbols-outlined text-[20px]">library_music</span>
              <%= t("nav.songs") %>
            <% end %>
            <% if current_user.admin? %>
              <%= link_to admin_path,
                    data: { action: "click->mobile-menu#close" },
                    class: "flex items-center gap-3 px-4 py-3 rounded-lg font-medium transition-colors #{request.path == '/admin' ? 'bg-primary/10 text-primary' : 'text-on-surface hover:bg-surface-container-low'}" do %>
                <span class="material-symbols-outlined text-[20px]">analytics</span>
                <%= t("nav.admin") %>
              <% end %>
            <% end %>
          </nav>

          <div class="border-t border-outline-variant/20 p-4 space-y-3">
            <%# Locale toggle — mobile %>
            <div class="flex items-center gap-1 bg-surface-container rounded-lg p-0.5 text-xs font-medium font-label w-fit">
              <%= button_to "EN", locale_path(locale: :en), method: :patch,
                    data: { action: "click->mobile-menu#close" },
                    class: "px-3 py-1.5 rounded-md transition-all cursor-pointer border-0 #{I18n.locale == :en ? 'bg-surface text-on-surface shadow-sm' : 'text-on-surface-variant hover:text-on-surface bg-transparent'}" %>
              <%= button_to "中文", locale_path(locale: :"zh-CN"), method: :patch,
                    data: { action: "click->mobile-menu#close" },
                    class: "px-3 py-1.5 rounded-md transition-all cursor-pointer border-0 #{I18n.locale == :"zh-CN" ? 'bg-surface text-on-surface shadow-sm' : 'text-on-surface-variant hover:text-on-surface bg-transparent'}" %>
            </div>

            <%= button_to t("nav.new_deck"), quick_create_decks_path, method: :post,
                  data: { action: "click->mobile-menu#close" },
                  class: "w-full bg-gradient-to-r from-primary to-primary-container text-on-primary px-5 py-3 rounded-xl font-medium hover:opacity-90 transition-all active:scale-95 duration-150 cursor-pointer" %>

            <div class="flex items-center justify-between px-4 py-2">
              <span class="text-sm text-on-surface-variant truncate flex-1 mr-4"><%= current_user.email %></span>
              <%= link_to destroy_user_session_path,
                    data: { turbo_method: :delete },
                    class: "text-on-surface-variant font-medium hover:text-primary transition-colors flex items-center gap-1" do %>
                <span class="material-symbols-outlined text-[18px]">logout</span>
                <span><%= t("nav.logout") %></span>
              <% end %>
            </div>
          </div>
        </div>
      </header>
    <% end %>

    <div id="flash-container" class="fixed top-[64px] right-4 z-50 flex flex-col gap-2 pointer-events-none">
      <% if notice %>
        <%= render "shared/flash_toast", type: :notice, message: notice %>
      <% end %>
      <% if alert %>
        <%= render "shared/flash_toast", type: :alert, message: alert %>
      <% end %>
    </div>

    <main class="<%= content_for?(:main_class) ? yield(:main_class) : 'max-w-5xl mx-auto px-6 py-8' %>">
      <%= yield %>
    </main>
  </body>
</html>
