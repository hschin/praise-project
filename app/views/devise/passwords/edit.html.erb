<div class="max-w-md mx-auto mt-12">
  <h1 class="text-2xl font-bold text-center mb-2">Praise Project</h1>
  <h2 class="text-lg text-stone-600 text-center mb-6">Change your password</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
    <%= render "shared/auth_errors", resource: resource %>

    <%= f.hidden_field :reset_password_token %>

    <div>
      <%= f.label :password, "New password", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-stone-400 mb-1"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
            class: "w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-600" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-600" %>
    </div>

    <%= f.submit "Change my password",
        class: "w-full bg-rose-700 text-white text-sm px-4 py-2 rounded-lg hover:bg-rose-800 cursor-pointer" %>
  <% end %>

  <div class="mt-4 space-y-1 text-sm text-stone-500">
    <%= render "devise/shared/links" %>
  </div>
</div>
