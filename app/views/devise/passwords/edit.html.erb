<% content_for :main_class, "min-h-screen bg-surface flex items-center justify-center px-6 py-12 relative overflow-hidden" %>

<%# Atmospheric blur blobs %>
<div class="absolute inset-0 pointer-events-none opacity-20">
  <div class="absolute -top-[10%] -left-[5%] w-[40%] h-[40%] rounded-full blur-[120px] bg-primary/10"></div>
  <div class="absolute -bottom-[10%] -right-[5%] w-[40%] h-[40%] rounded-full blur-[120px] bg-tertiary/10"></div>
</div>

<div class="w-full max-w-[440px] z-10">
  <div class="bg-surface-container-lowest rounded-xl p-8 md:p-12 shadow-[0_10px_40px_rgba(31,27,23,0.06)] border border-outline-variant/10">
    <%# Brand anchor %>
    <div class="text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-headline italic text-primary tracking-tight">Praise Project</h1>
      <div class="w-12 h-px bg-outline-variant/40 mx-auto mt-6"></div>
    </div>

    <%# Form header %>
    <div class="mb-8">
      <h2 class="text-2xl font-headline text-on-surface">Change Password</h2>
      <p class="text-on-surface-variant text-sm mt-2 font-body">Choose a new password for your account.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
      <%= render "shared/auth_errors", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="space-y-1.5">
        <%= f.label :password, "New Password", class: "block text-[0.75rem] font-semibold uppercase tracking-wider text-on-surface-variant font-label" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-on-surface-variant/60 font-body"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
        <div class="relative group">
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
              class: "w-full bg-transparent border-0 border-b border-outline-variant/30 py-3 px-0 focus:ring-0 focus:border-primary transition-all font-body text-on-surface placeholder:text-on-surface-variant/40",
              placeholder: "••••••••" %>
          <div class="absolute bottom-0 left-0 h-0.5 bg-primary w-0 group-focus-within:w-full transition-all duration-300"></div>
        </div>
      </div>

      <div class="space-y-1.5">
        <%= f.label :password_confirmation, "Confirm New Password", class: "block text-[0.75rem] font-semibold uppercase tracking-wider text-on-surface-variant font-label" %>
        <div class="relative group">
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full bg-transparent border-0 border-b border-outline-variant/30 py-3 px-0 focus:ring-0 focus:border-primary transition-all font-body text-on-surface placeholder:text-on-surface-variant/40",
              placeholder: "••••••••" %>
          <div class="absolute bottom-0 left-0 h-0.5 bg-primary w-0 group-focus-within:w-full transition-all duration-300"></div>
        </div>
      </div>

      <div class="pt-2">
        <%= f.submit "Change My Password", class: "w-full bg-gradient-to-r from-primary to-primary-container text-on-primary py-4 px-6 rounded-lg font-medium tracking-wide shadow-sm hover:shadow-md hover:opacity-95 active:scale-[0.98] transition-all duration-200 cursor-pointer" %>
      </div>
    <% end %>

    <div class="mt-10 flex flex-col items-center space-y-4 text-sm">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
