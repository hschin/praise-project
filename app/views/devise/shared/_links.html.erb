<%- if controller_name != 'sessions' %>
  <%= link_to "Sign in to your account", new_session_path(resource_name), class: "block text-indigo-600 hover:underline" %>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <%= link_to "Create an account", new_registration_path(resource_name), class: "block text-indigo-600 hover:underline" %>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <%= link_to "Forgot your password?", new_password_path(resource_name), class: "block text-gray-500 hover:underline" %>
<% end %>
