<%- if controller_name != 'sessions' %>
  <%= link_to "Sign in to your account", new_session_path(resource_name), class: "text-primary font-semibold hover:underline decoration-outline-variant underline-offset-4" %>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <%= link_to "Create an account", new_registration_path(resource_name), class: "text-primary font-semibold hover:underline decoration-outline-variant underline-offset-4" %>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-tertiary hover:text-on-tertiary-fixed-variant transition-colors font-medium" %>
<% end %>
