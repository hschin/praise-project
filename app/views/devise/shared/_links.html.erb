<%- if controller_name != 'sessions' %>
  <%= link_to "Sign in to your account", new_session_path(resource_name), class: "text-on-surface-variant hover:text-primary transition-colors font-medium" %>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <%= link_to "Create an account", new_registration_path(resource_name), class: "text-on-surface-variant hover:text-primary transition-colors font-medium" %>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-on-surface-variant hover:text-primary transition-colors font-medium" %>
<% end %>
