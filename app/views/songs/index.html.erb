<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Song Library</h1>
  <%= link_to "Add Song", new_song_path, class: "bg-indigo-600 text-white text-sm px-4 py-2 rounded hover:bg-indigo-700" %>
</div>

<%= form_with url: songs_path, method: :get, class: "mb-4" do |f| %>
  <%= f.text_field :q, value: params[:q], placeholder: "Search by title or artist...", class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
<% end %>

<% if @songs.any? %>
  <div class="bg-white rounded border border-gray-200 divide-y divide-gray-100">
    <% @songs.each do |song| %>
      <div class="flex items-center justify-between px-4 py-3">
        <div>
          <%= link_to song.title, song_path(song), class: "font-medium text-gray-900 hover:text-indigo-600" %>
          <span class="text-sm text-gray-500 ml-2"><%= song.artist %></span>
        </div>
        <div class="flex items-center gap-4 text-sm">
          <span class="text-gray-400"><%= song.default_key %></span>
          <%= link_to "Edit", edit_song_path(song), class: "text-indigo-600 hover:underline" %>
          <%= button_to "Delete", song_path(song), method: :delete, data: { turbo_confirm: "Delete \"#{song.title}\"?" }, class: "text-red-500 hover:underline bg-transparent border-0 cursor-pointer p-0 text-sm" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-gray-500 text-sm">No songs found. <%= link_to "Add one", new_song_path, class: "text-indigo-600 hover:underline" %>.</p>
<% end %>
