<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-stone-900">Song Library</h1>
  </div>

  <%# Search and import form %>
  <div class="bg-white border border-stone-200 rounded-lg p-4 mb-6">
    <h2 class="text-sm font-semibold text-stone-700 mb-3">Search for a song</h2>
    <%= form_with url: import_songs_path, method: :post, data: { turbo: false }, class: "flex gap-2 mb-4" do |f| %>
      <%= f.text_field :title,
            placeholder: "Song title (Chinese or English)...",
            class: "flex-1 border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-600" %>
      <%= f.submit "Import",
            class: "bg-rose-700 text-white text-sm px-4 py-2 rounded-lg hover:bg-rose-800 cursor-pointer" %>
    <% end %>

    <%# LOCKED: Manual paste always visible as secondary option %>
    <details class="text-sm">
      <summary class="cursor-pointer text-stone-500 hover:text-stone-700">Paste lyrics manually instead</summary>
      <div class="mt-3">
        <%= form_with url: import_songs_path, method: :post, data: { turbo: false }, class: "space-y-2" do |f| %>
          <%= f.text_field :title,
                placeholder: "Song title",
                class: "w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-600" %>
          <%= f.text_area :raw_lyrics,
                placeholder: "Paste raw lyrics here — any format accepted",
                rows: 6,
                class: "w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-600" %>
          <%= f.submit "Import Pasted Lyrics",
                class: "bg-stone-700 text-white text-sm px-4 py-2 rounded-lg hover:bg-stone-800 cursor-pointer" %>
        <% end %>
      </div>
    </details>
  </div>

  <%# Library search (title filter) %>
  <%= form_with url: songs_path, method: :get, class: "flex gap-2 mb-4" do |f| %>
    <%= f.text_field :q,
          value: params[:q],
          placeholder: "Filter by title...",
          class: "flex-1 border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-600" %>
    <%= f.submit "Search", class: "bg-white border border-stone-200 text-sm px-4 py-2 rounded-lg hover:bg-stone-50 cursor-pointer" %>
  <% end %>

  <%# Song cards %>
  <% if @songs.any? %>
    <div class="space-y-2">
      <% @songs.each do |song| %>
        <div class="relative group bg-white border border-stone-200 rounded-lg hover:border-rose-300 hover:shadow-sm transition-all">
          <%= link_to song_path(song), class: "block p-4 focus:outline-none" do %>
            <p class="font-medium text-stone-900"><%= song.title %></p>
            <%# LOCKED: First lyric line preview (not section count) %>
            <% first_lyric = song.lyrics.order(:position).first %>
            <% if first_lyric %>
              <p class="text-sm text-stone-500 mt-0.5 truncate"><%= first_lyric.content.to_s.split("\n").first %></p>
            <% end %>
          <% end %>
          <div class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity">
            <%= button_to song_path(song), method: :delete,
                  data: { turbo_confirm: "Delete \"#{song.title}\"?" },
                  class: "p-1.5 text-stone-400 hover:text-red-600 bg-transparent border-0 cursor-pointer rounded" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.021-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-8">
      <div class="mx-auto w-8 h-8 text-stone-300 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z" />
        </svg>
      </div>
      <p class="text-sm text-stone-400">Import a song above to build your library.</p>
    </div>
  <% end %>
</div>
