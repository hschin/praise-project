<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Song Library</h1>
  </div>

  <%# Search and import form %>
  <div class="bg-white border border-gray-200 rounded-lg p-4 mb-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">Search for a song</h2>
    <%= form_with url: import_songs_path, method: :post, class: "flex gap-2 mb-4" do |f| %>
      <%= f.text_field :title,
            placeholder: "Song title (Chinese or English)...",
            class: "flex-1 border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      <%= f.submit "Import",
            class: "bg-indigo-600 text-white text-sm px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
    <% end %>

    <%# LOCKED: Manual paste always visible as secondary option %>
    <details class="text-sm">
      <summary class="cursor-pointer text-gray-500 hover:text-gray-700">Paste lyrics manually instead</summary>
      <div class="mt-3">
        <%= form_with url: import_songs_path, method: :post, class: "space-y-2" do |f| %>
          <%= f.text_field :title,
                placeholder: "Song title",
                class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          <%= f.text_area :raw_lyrics,
                placeholder: "Paste raw lyrics here — any format accepted",
                rows: 6,
                class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          <%= f.submit "Import Pasted Lyrics",
                class: "bg-gray-700 text-white text-sm px-4 py-2 rounded hover:bg-gray-800 cursor-pointer" %>
        <% end %>
      </div>
    </details>
  </div>

  <%# Library search (title filter) %>
  <%= form_with url: songs_path, method: :get, class: "flex gap-2 mb-4" do |f| %>
    <%= f.text_field :q,
          value: params[:q],
          placeholder: "Filter by title...",
          class: "flex-1 border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    <%= f.submit "Search", class: "bg-white border border-gray-300 text-sm px-4 py-2 rounded hover:bg-gray-50 cursor-pointer" %>
  <% end %>

  <%# Song cards %>
  <% if @songs.any? %>
    <div class="space-y-2">
      <% @songs.each do |song| %>
        <%= link_to song_path(song), class: "block bg-white border border-gray-200 rounded-lg p-4 hover:border-indigo-300 hover:shadow-sm transition-all" do %>
          <div class="flex items-start justify-between">
            <div>
              <p class="font-medium text-gray-900"><%= song.title %></p>
              <%# LOCKED: First lyric line preview (not section count) %>
              <% first_lyric = song.lyrics.order(:position).first %>
              <% if first_lyric %>
                <p class="text-sm text-gray-500 mt-0.5 truncate"><%= first_lyric.content.to_s.split("\n").first %></p>
              <% end %>
            </div>
            <span class="text-xs px-2 py-0.5 rounded-full ml-3 flex-shrink-0 <%= song.done? ? 'bg-green-100 text-green-700' : song.failed? ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700' %>">
              <%= song.import_status %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 text-gray-400">
      <p class="text-lg mb-1">No songs yet</p>
      <p class="text-sm">Search for a song above to get started</p>
    </div>
  <% end %>
</div>
