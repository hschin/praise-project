<div data-controller="song-search">

  <div class="mb-12">
    <h1 class="font-headline text-4xl md:text-5xl text-on-surface mb-2 tracking-tight">Song Library</h1>
    <p class="text-on-surface-variant font-body">Curate and organize your congregation's spiritual soundtrack.</p>
  </div>

  <%# Unified search panel %>
  <section class="bg-surface-container-low rounded-xl p-8 mb-8"
           style="box-shadow: 0 10px 40px rgba(31,27,23,0.06);">

    <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant mb-2">Search songs</label>

    <div class="flex gap-3 mb-2">
      <input type="text"
             data-song-search-target="input"
             data-action="input->song-search#filter"
             placeholder="Song title or 'Title - Artist' to search or import..."
             class="flex-1 bg-surface-container-lowest border-0 focus:ring-2 focus:ring-primary rounded-lg h-12 px-4 text-on-surface placeholder:text-on-surface-variant/40 font-body">
    </div>

    <%# Shown only when no library matches %>
    <div data-song-search-target="importSection" hidden class="mt-4 space-y-4">
      <div class="flex items-center gap-3 p-4 bg-surface-container border border-dashed border-outline-variant/40 rounded-lg">
        <span class="material-symbols-outlined text-outline/60">info</span>
        <p class="text-sm text-on-surface-variant font-body flex-1">Not in your library — import from web?</p>
        <%= form_with url: import_songs_path, method: :post, data: { turbo: false }, class: "flex gap-2 flex-shrink-0" do |f| %>
          <%= f.text_field :title,
                data: { "song-search-target": "importTitle" },
                class: "hidden" %>
          <%= f.submit "Import",
                class: "h-10 px-6 bg-tertiary text-on-tertiary rounded-lg font-medium hover:bg-tertiary-container transition-colors cursor-pointer text-sm" %>
        <% end %>
      </div>

      <%# Manual paste %>
      <details class="group">
        <summary class="cursor-pointer text-primary font-medium flex items-center gap-2 select-none hover:underline decoration-outline-variant text-sm">
          <span class="material-symbols-outlined text-[18px] transition-transform group-open:rotate-180">expand_more</span>
          Paste lyrics manually instead
        </summary>
        <div class="mt-4 space-y-3">
          <%= form_with url: import_songs_path, method: :post, data: { turbo: false }, class: "space-y-3" do |f| %>
            <%= f.text_field :title,
                  data: { "song-search-target": "importTitle" },
                  placeholder: "Song title",
                  class: "w-full bg-surface-container-lowest border-0 focus:ring-2 focus:ring-primary rounded-lg h-10 px-4 text-on-surface placeholder:text-on-surface-variant/40 font-body text-sm" %>
            <%= f.text_area :raw_lyrics,
                  placeholder: "Paste raw lyrics here — any format accepted",
                  rows: 6,
                  class: "w-full bg-surface-container-highest/50 border-0 rounded-lg p-4 focus:ring-2 focus:ring-primary text-on-surface placeholder:text-on-surface-variant/40 font-body text-sm" %>
            <div class="flex justify-end">
              <%= f.submit "Import Pasted Lyrics",
                    class: "bg-gradient-to-r from-primary to-primary-container text-on-primary px-6 py-2 rounded-lg font-medium hover:opacity-95 transition-all cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </details>
    </div>

    <%# Shown when library has songs but none match %>
    <p data-song-search-target="empty" hidden
       class="text-sm text-on-surface-variant/60 font-body mt-2 px-1">
      No songs in your library match that title.
    </p>
  </section>

  <%# Song list %>
  <% if @songs.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      <% @songs.each do |song| %>
        <div class="group rounded-xl bg-surface-container-low/40 hover:bg-surface-container-low transition-all duration-200 shadow-[0_1px_3px_rgba(31,27,23,0.02)] hover:shadow-[0_4px_12px_rgba(31,27,23,0.06)] border border-outline-variant/8 overflow-hidden"
             data-song-search-target="item"
             data-title="<%= song.title %>">
          <div class="flex items-start justify-between p-5 pb-3">
            <%= link_to song_path(song), class: "flex-1 min-w-0 focus:outline-none" do %>
              <h3 class="font-headline text-xl text-on-surface group-hover:text-primary transition-colors leading-tight truncate"><%= song.title %></h3>
              <p class="text-sm text-on-surface-variant/70 font-body mt-0.5 truncate min-h-[1.25rem]"><%= song.english_title %></p>
              <div class="flex items-center gap-2 mt-1.5 overflow-hidden">
                <% meta = [] %>
                <% meta << { icon: "person",     label: song.artist }                    if song.artist.present? %>
                <% meta << { icon: "music_note",  label: "Key #{song.default_key}" }     if song.default_key.present? %>
                <% meta << { icon: "tag",          label: "CCLI #{song.ccli_number}" }   if song.ccli_number.present? %>
                <% if meta.any? %>
                  <% meta.each_with_index do |m, i| %>
                    <% unless i == 0 %>
                      <span class="text-outline/30 text-xs flex-shrink-0">·</span>
                    <% end %>
                    <span class="inline-flex items-center gap-0.5 text-xs text-on-surface-variant font-body flex-shrink-0">
                      <span class="material-symbols-outlined text-[13px] text-outline"><%=m[:icon]%></span>
                      <span class="truncate"><%= m[:label] %></span>
                    </span>
                  <% end %>
                <% else %>
                  <span class="min-h-[1rem]"></span>
                <% end %>
              </div>
            <% end %>
            <div class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 ml-4 mt-0.5">
              <%= button_to song_path(song), method: :delete,
                    data: { turbo_confirm: "Delete \"#{song.title}\"?" },
                    class: "p-2 text-error hover:bg-error-container rounded-full transition-all cursor-pointer bg-transparent border-0" do %>
                <span class="material-symbols-outlined text-[18px]">delete</span>
              <% end %>
            </div>
          </div>
          <% first_lyric = song.lyrics.order(:position).first %>
          <% if first_lyric %>
            <% preview_lines = first_lyric.content.to_s.split("\n").first(4) %>
            <%= link_to song_path(song), class: "block px-5 pb-4 focus:outline-none" do %>
              <div class="border-t border-outline-variant/10 pt-3">
                <% preview_lines.each do |line| %>
                  <p class="text-sm text-on-surface-variant/60 font-body italic leading-relaxed"><%= line %></p>
                <% end %>
                <% if first_lyric.content.to_s.split("\n").length > 4 %>
                  <p class="text-xs text-outline/50 font-body mt-1">…</p>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="mt-12 text-center py-12 border-t border-dashed border-outline-variant/30">
      <span class="material-symbols-outlined text-outline text-5xl mb-4">library_music</span>
      <p class="font-headline text-on-surface-variant italic">"He put a new song in my mouth, a hymn of praise to our God."</p>
    </div>
  <% end %>

</div>
