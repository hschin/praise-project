<div data-controller="song-search">

  <div class="mb-12">
    <h1 class="font-headline text-4xl md:text-5xl text-on-surface mb-2 tracking-tight">Song Library</h1>
    <p class="text-on-surface-variant font-body">Curate and organize your congregation's spiritual soundtrack.</p>
  </div>

  <%# Search bar %>
  <section class="bg-surface-container-low rounded-xl p-6 mb-8"
           style="box-shadow: 0 10px 40px rgba(31,27,23,0.06);">
    <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant mb-2">Search songs</label>
    <input type="text"
           data-song-search-target="input"
           data-action="input->song-search#filter"
           placeholder="Search by title, English name, or artist..."
           class="w-full bg-surface-container-lowest border-0 focus:ring-2 focus:ring-primary rounded-lg h-12 px-4 text-on-surface placeholder:text-on-surface-variant/40 font-body">
    <p data-song-search-target="empty" hidden
       class="text-sm text-on-surface-variant/60 font-body mt-3 px-1">
      No songs in your library match that title.
    </p>
  </section>

  <%# Song list %>
  <% if @songs.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      <% @songs.each do |song| %>
        <div class="group rounded-xl bg-surface-container-low/40 hover:bg-surface-container-low transition-all duration-200 shadow-[0_1px_3px_rgba(31,27,23,0.02)] hover:shadow-[0_4px_12px_rgba(31,27,23,0.06)] border border-outline-variant/8 overflow-hidden"
             data-song-search-target="item"
             data-title="<%= song.title %>"
             data-english-title="<%= song.english_title %>"
             data-artist="<%= song.artist %>">
          <div class="flex items-start p-5 pb-3">
            <%= link_to song_path(song), class: "flex-1 min-w-0 focus:outline-none" do %>
              <h3 class="font-headline text-xl text-on-surface group-hover:text-primary transition-colors leading-tight truncate"><%= song.title %></h3>
              <p class="text-sm text-on-surface-variant/70 font-body mt-0.5 truncate min-h-[1.25rem]"><%= song.english_title %></p>
              <div class="flex items-center gap-2 mt-1.5 overflow-hidden min-w-0">
                <% meta = [
                     { icon: "person",     label: song.artist.presence,       placeholder: "—" },
                     { icon: "music_note", label: song.default_key.presence,  placeholder: "—" },
                     { icon: "tag",        label: song.ccli_number.presence ? "CCLI #{song.ccli_number}" : nil, placeholder: "—" },
                   ] %>
                <% meta.each_with_index do |m, i| %>
                  <% unless i == 0 %>
                    <span class="text-outline/30 text-xs flex-shrink-0">·</span>
                  <% end %>
                  <span class="inline-flex items-center gap-0.5 text-xs font-body <%= i == 0 ? 'min-w-0 shrink' : 'flex-shrink-0' %> <%= m[:label] ? 'text-on-surface-variant' : 'text-outline/50' %>">
                    <span class="material-symbols-outlined text-outline/60 flex-shrink-0" style="font-size:14px;line-height:1"><%= m[:icon] %></span>
                    <span class="truncate"><%= m[:label] || m[:placeholder] %></span>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>
          <% first_lyric = song.lyrics.order(:position).first %>
          <% if first_lyric %>
            <% preview_lines = first_lyric.content.to_s.split("\n").first(4) %>
            <%= link_to song_path(song), class: "block px-5 pb-4 focus:outline-none" do %>
              <div class="border-t border-outline-variant/10 pt-3">
                <% preview_lines.each do |line| %>
                  <p class="text-sm text-on-surface-variant/60 font-body italic leading-relaxed"><%= line %></p>
                <% end %>
                <% if first_lyric.content.to_s.split("\n").length > 4 %>
                  <p class="text-xs text-outline/50 font-body mt-1">…</p>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <%# Import from web card %>
      <%= form_with url: import_songs_path, method: :post, data: { turbo: false } do |f| %>
        <%= f.hidden_field :title, data: { "song-search-target": "importTitle" } %>
        <button type="submit" class="w-full h-full text-left rounded-xl bg-surface-container-low border border-outline-variant/20 hover:bg-surface-container hover:shadow-md active:scale-[0.98] transition-all p-5 flex items-center gap-4 group shadow-sm cursor-pointer">
          <div class="w-10 h-10 rounded-full bg-tertiary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-tertiary/20 transition-colors">
            <span class="material-symbols-outlined text-tertiary text-[20px]">language</span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-headline text-base text-on-surface group-hover:text-primary transition-colors">Import from web</p>
            <p class="text-xs text-on-surface-variant font-body mt-0.5">Claude searches and structures lyrics automatically</p>
          </div>
          <span class="material-symbols-outlined text-outline/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all">arrow_forward</span>
        </button>
      <% end %>

      <%# Paste lyrics card %>
      <%= link_to new_song_path, data: { "song-search-target": "pastePath" },
            class: "rounded-xl bg-surface-container-low border border-outline-variant/20 hover:bg-surface-container hover:shadow-md active:scale-[0.98] transition-all p-5 flex items-center gap-4 group shadow-sm" do %>
        <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
          <span class="material-symbols-outlined text-primary text-[20px]">content_paste</span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-headline text-base text-on-surface group-hover:text-primary transition-colors">Paste lyrics</p>
          <p class="text-xs text-on-surface-variant font-body mt-0.5">Already have lyrics? Claude will add pinyin</p>
        </div>
        <span class="material-symbols-outlined text-outline/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all">arrow_forward</span>
      <% end %>

    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      <%# Import from web card %>
      <%= form_with url: import_songs_path, method: :post, data: { turbo: false } do |f| %>
        <%= f.hidden_field :title, data: { "song-search-target": "importTitle" } %>
        <button type="submit" class="w-full h-full text-left rounded-xl border border-dashed border-outline-variant/40 bg-surface-container-low/20 hover:bg-surface-container-low hover:border-outline-variant/60 transition-all p-5 flex flex-col gap-2 group">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors text-[20px]">language</span>
            <h3 class="font-headline text-lg text-on-surface group-hover:text-primary transition-colors">Import from web</h3>
          </div>
          <p class="text-xs text-on-surface-variant font-body">Claude will search and structure the lyrics automatically.</p>
        </button>
      <% end %>

      <%# Paste lyrics card %>
      <%= link_to new_song_path,
            class: "rounded-xl border border-dashed border-outline-variant/40 bg-surface-container-low/20 hover:bg-surface-container-low hover:border-outline-variant/60 transition-all p-5 flex flex-col gap-2 group" do %>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors text-[20px]">content_paste</span>
          <h3 class="font-headline text-lg text-on-surface group-hover:text-primary transition-colors">Paste lyrics</h3>
        </div>
        <p class="text-xs text-on-surface-variant font-body">Already have the lyrics? Paste them in and Claude will add pinyin.</p>
      <% end %>
    </div>
  <% end %>

</div>
