<div class="bg-error-container text-on-error-container rounded-xl p-6">
  <div class="flex items-start gap-3">
    <span class="material-symbols-outlined text-xl flex-shrink-0 mt-0.5">warning</span>
    <div class="flex-1">
      <h3 class="text-sm font-semibold">Couldn't find lyrics for "<%= title %>". Try pasting them manually below.</h3>
      <div class="mt-4">
        <p class="text-sm font-medium mb-2">Paste lyrics manually:</p>
        <%= form_with url: import_songs_path, method: :post, class: "space-y-3" do |f| %>
          <%= hidden_field_tag :title, title %>
          <%= f.text_area :raw_lyrics,
                placeholder: "Paste raw lyrics here — any format accepted",
                rows: 8,
                class: "w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary text-on-surface font-body" %>
          <%= f.submit "Import Pasted Lyrics",
                class: "bg-gradient-to-r from-primary to-primary-container text-on-primary text-sm px-4 py-2 rounded-lg font-medium hover:opacity-95 active:scale-[0.98] transition-all cursor-pointer" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
