<div class="bg-red-50 border border-red-200 rounded-lg p-6">
  <div class="flex items-start gap-3">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 flex-shrink-0 text-red-500">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
    </svg>
    <div>
      <h3 class="text-sm font-semibold text-red-800">Couldn't find lyrics for "<%= title %>". Try pasting them manually below.</h3>
      <div class="mt-4">
        <p class="text-sm font-medium text-stone-700 mb-2">Paste lyrics manually:</p>
        <%= form_with url: import_songs_path, method: :post, class: "space-y-3" do |f| %>
          <%= hidden_field_tag :title, title %>
          <%= f.text_area :raw_lyrics,
                placeholder: "Paste raw lyrics here — any format accepted",
                rows: 8,
                class: "w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-600" %>
          <%= f.submit "Import Pasted Lyrics",
                class: "bg-rose-700 text-white text-sm px-4 py-2 rounded-lg hover:bg-rose-800 cursor-pointer" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
