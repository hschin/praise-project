<%= form_with model: song, class: "space-y-6" do |f| %>
  <% if song.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-3 text-sm text-red-700">
      <% song.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%# Song metadata %>
  <div class="space-y-4">
    <div>
      <%= f.label :title, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :title,
            class: "w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-600" %>
    </div>
    <div>
      <%= f.label :artist, class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.text_field :artist,
            class: "w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-600" %>
    </div>
    <div>
      <%= f.label :default_key, "Default Key", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.select :default_key, ["C", "C#", "D", "Eb", "E", "F", "F#", "G", "Ab", "A", "Bb", "B"],
          { include_blank: "Select key" },
          class: "w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-600" %>
    </div>
  </div>

  <%# Nested lyric sections — LOCKED: section_type, content, and pinyin all editable %>
  <% if song.lyrics.any? %>
    <div class="space-y-5">
      <h2 class="text-sm font-semibold text-stone-700 border-b pb-2">Lyrics Sections</h2>
      <%= f.fields_for :lyrics, song.lyrics.order(:position) do |lf| %>
        <div class="bg-stone-50 border border-stone-200 rounded-lg p-4 space-y-3">
          <div>
            <%= lf.label :section_type, "Section Label", class: "block text-xs font-medium text-stone-600 mb-1" %>
            <%= lf.text_field :section_type,
                  class: "border border-stone-200 rounded-lg px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-amber-600",
                  placeholder: "verse, chorus, bridge..." %>
          </div>
          <div>
            <%= lf.label :content, "Lyrics (Chinese)", class: "block text-xs font-medium text-stone-600 mb-1" %>
            <%= lf.text_area :content,
                  rows: 4,
                  class: "w-full border border-stone-200 rounded-lg px-2 py-1 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-amber-600",
                  placeholder: "One character per token, lines separated by newlines" %>
          </div>
          <div>
            <%= lf.label :pinyin, "Pinyin", class: "block text-xs font-medium text-stone-600 mb-1" %>
            <%= lf.text_area :pinyin,
                  rows: 4,
                  class: "w-full border border-stone-200 rounded-lg px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-amber-600",
                  placeholder: "Space-separated tone-marked pinyin, lines separated by newlines" %>
          </div>
          <%= lf.hidden_field :id %>
          <%= lf.hidden_field :position %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-stone-400 italic">No lyrics yet — lyrics appear here after import completes.</p>
  <% end %>

  <div class="flex gap-3 pt-2">
    <%= f.submit "Save Changes",
          class: "bg-amber-800 text-white text-sm px-4 py-2 rounded-lg hover:bg-amber-900 cursor-pointer" %>
    <%= link_to "Cancel", song_path(song), class: "text-sm text-stone-500 hover:underline self-center" %>
  </div>
<% end %>
