<%= turbo_stream_from "song_search_#{[@title, @artist].compact.join('_').parameterize}" %>

<div class="max-w-2xl mx-auto px-4 py-16">
  <p class="text-xs font-label uppercase tracking-widest text-on-surface-variant mb-3"><%= t("songs.searching") %></p>
  <h1 class="font-headline text-4xl text-on-surface mb-2"><%= @title %></h1>
  <% if @artist.present? %>
    <p class="text-on-surface-variant font-body mb-10"><%= t("songs.by_artist", artist: @artist) %></p>
  <% end %>

  <div id="search_results">
    <div class="bg-surface-container-low rounded-xl overflow-hidden"
         data-controller="progress"
         data-progress-start-value="0"
         data-progress-end-value="85"
         data-progress-duration-value="6000">

      <%# Progress bar %>
      <div class="h-1 bg-surface-container-high relative overflow-hidden">
        <div class="h-full bg-gradient-to-r from-primary to-primary-container transition-all duration-700 ease-out w-0"
             data-progress-target="bar"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent animate-shimmer"></div>
      </div>

      <div class="flex items-center gap-3 p-6">
        <div class="animate-spin h-5 w-5 border-2 border-primary border-t-transparent rounded-full"></div>
        <div class="flex-1">
          <p class="text-on-surface font-body font-medium"><%= t("songs.searching_status") %></p>
          <p class="text-xs text-on-surface-variant font-body mt-0.5 animate-pulse-text">
            <%= t("songs.searching_detail") %><span class="animate-dots">…</span>
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <% if @deck_id.present? %>
      <%= link_to deck_path(@deck_id), class: "inline-flex items-center gap-1 text-xs text-on-surface-variant hover:text-primary transition-colors font-body" do %>
        <span class="material-symbols-outlined text-[14px]">arrow_back</span>
        <%= t("songs.back_to_deck") %>
      <% end %>
    <% else %>
      <%= link_to songs_path, class: "inline-flex items-center gap-1 text-xs text-on-surface-variant hover:text-primary transition-colors font-body" do %>
        <span class="material-symbols-outlined text-[14px]">arrow_back</span>
        <%= t("songs.back_to_library") %>
      <% end %>
    <% end %>
  </div>
</div>

<style>
  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  @keyframes pulse-text {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  @keyframes dots {
    0%, 20% { content: ''; }
    40% { content: '.'; }
    60% { content: '..'; }
    80%, 100% { content: '...'; }
  }

  .animate-shimmer {
    animation: shimmer 2s infinite;
  }

  .animate-pulse-text {
    animation: pulse-text 2s ease-in-out infinite;
  }

  .animate-dots::after {
    content: '...';
    animation: dots 1.5s steps(4, end) infinite;
  }
</style>
