<%= turbo_stream_from "song_import_#{@title.parameterize}" %>

<div class="max-w-lg mx-auto px-4 py-16">
  <p class="text-xs font-label uppercase tracking-widest text-on-surface-variant mb-3">Importing song</p>
  <h1 class="font-headline text-4xl text-on-surface mb-10"><%= @title %></h1>

  <div id="import_status">
    <%= render "songs/processing", step: (params[:step] || "searching") %>
  </div>

  <div class="mt-10">
    <% if @deck_id.present? %>
      <%= link_to deck_path(@deck_id), class: "inline-flex items-center gap-1 text-xs text-on-surface-variant hover:text-primary transition-colors font-body" do %>
        <span class="material-symbols-outlined text-[14px]">arrow_back</span>
        Back to deck
      <% end %>
    <% else %>
      <%= link_to songs_path, class: "inline-flex items-center gap-1 text-xs text-on-surface-variant hover:text-primary transition-colors font-body" do %>
        <span class="material-symbols-outlined text-[14px]">arrow_back</span>
        Song Library
      <% end %>
    <% end %>
  </div>
</div>
