<%= turbo_stream_from "song_import_#{@title.parameterize}" %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= @title %></h1>
    <%= link_to "Back to Library", songs_path, class: "text-sm text-indigo-600 hover:underline" %>
  </div>

  <div id="import_status">
    <%= render "songs/processing", step: "searching" %>
  </div>
</div>
