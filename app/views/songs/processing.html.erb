<%= turbo_stream_from "song_import_#{@title.parameterize}" %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="font-headline text-3xl text-on-surface"><%= @title %></h1>
    <% if @deck_id.present? %>
      <%= link_to "Back to Deck", deck_path(@deck_id), class: "text-sm text-primary hover:underline decoration-outline-variant font-body" %>
    <% else %>
      <%= link_to "Back to Library", songs_path, class: "text-sm text-primary hover:underline decoration-outline-variant font-body" %>
    <% end %>
  </div>

  <div id="import_status">
    <%= render "songs/processing", step: "searching" %>
  </div>
</div>
