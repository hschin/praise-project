<div data-controller="pinyin-toggle">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-2">
      <%= link_to edit_song_path(song), class: "inline-flex items-center gap-1 text-xs bg-surface-container hover:bg-surface-container-high px-3 py-1.5 rounded-lg text-on-surface-variant hover:text-primary font-body transition-colors" do %>
        <span class="material-symbols-outlined text-[14px]">edit</span>
        <%= t("songs.lyrics.edit") %>
      <% end %>
      <%= button_to song_path(song), method: :delete,
            data: { turbo_confirm: t("songs.lyrics.delete_confirm", title: song.title) },
            form_class: "flex items-center",
            class: "inline-flex items-center gap-1 text-xs bg-surface-container hover:bg-error-container px-3 py-1.5 rounded-lg text-on-surface-variant hover:text-on-error-container font-body transition-colors cursor-pointer border-0" do %>
        <span class="material-symbols-outlined text-[14px]">delete</span>
        <%= t("songs.lyrics.delete") %>
      <% end %>
    </div>
    <button data-pinyin-toggle-target="button"
            data-action="click->pinyin-toggle#toggle"
            data-hide-text="<%= t("songs.lyrics.hide_pinyin") %>"
            data-show-text="<%= t("songs.lyrics.show_pinyin") %>"
            class="text-sm bg-surface-container hover:bg-surface-container-high px-3 py-1 rounded-lg text-on-surface-variant font-body transition-colors">
      <%= t("songs.lyrics.hide_pinyin") %>
    </button>
  </div>

  <div data-pinyin-toggle-target="container" class="space-y-4">
    <% song.lyrics.order(:position).each do |lyric| %>
      <div class="lyric-section border border-outline-variant/20 rounded-lg overflow-hidden">
        <div class="bg-surface-container-high border-b border-outline-variant/10 px-4 py-2">
          <h3 class="text-xs font-semibold uppercase tracking-widest text-on-surface-variant font-label">
            <%= localized_section_type(lyric.section_type) %>
          </h3>
        </div>
        <div class="bg-surface-container-lowest px-4 py-3 text-lg leading-loose font-body">
          <% content_lines = lyric.content.to_s.split("\n") %>
          <% pinyin_lines  = lyric.pinyin.to_s.split("\n") %>
          <% content_lines.each_with_index do |line, line_idx| %>
            <div class="mb-1">
              <% chars  = line.chars %>
              <% tokens = (pinyin_lines[line_idx] || "").split(" ") %>
              <% pinyin_idx = 0 %>
              <% chars.each do |char| %>
                <% if char.match?(/\p{Han}/) %>
                  <ruby><%= char %><rp>(</rp><rt><%= tokens[pinyin_idx] %></rt><rp>)</rp></ruby>
                  <% pinyin_idx += 1 %>
                <% else %>
                  <ruby><%= char %><rt></rt></ruby>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
