<div data-controller="pinyin-toggle" class="import-success">
  <div class="flex items-center justify-between mb-4">
    <div class="flex gap-3">
      <%= link_to "Edit", edit_song_path(song), class: "text-sm text-indigo-600 hover:underline" %>
    </div>
    <button data-pinyin-toggle-target="button"
            data-action="click->pinyin-toggle#toggle"
            class="text-sm bg-gray-100 hover:bg-gray-200 px-3 py-1 rounded text-gray-700">
      Hide Pinyin
    </button>
  </div>

  <div data-pinyin-toggle-target="container" class="space-y-6">
    <% song.lyrics.order(:position).each do |lyric| %>
      <div class="lyric-section">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-2">
          <%= lyric.section_type.humanize %>
        </h3>
        <div class="text-lg leading-loose">
          <% content_lines = lyric.content.to_s.split("\n") %>
          <% pinyin_lines  = lyric.pinyin.to_s.split("\n") %>
          <% content_lines.each_with_index do |line, line_idx| %>
            <div class="mb-1">
              <% chars  = line.chars %>
              <% tokens = (pinyin_lines[line_idx] || "").split(" ") %>
              <% chars.each_with_index do |char, char_idx| %>
                <ruby><%= char %><rp>(</rp><rt><%= tokens[char_idx] %></rt><rp>)</rp></ruby>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
