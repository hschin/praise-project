<div data-controller="pinyin-toggle">
  <div class="flex items-center justify-between mb-4">
    <div class="flex gap-3">
      <%= link_to "Edit", edit_song_path(song), class: "text-sm text-indigo-600 hover:underline" %>
    </div>
    <button data-pinyin-toggle-target="button"
            data-action="click->pinyin-toggle#toggle"
            class="text-sm bg-gray-100 hover:bg-gray-200 px-3 py-1 rounded text-gray-700">
      Hide Pinyin
    </button>
  </div>

  <div data-pinyin-toggle-target="container" class="space-y-4">
    <% song.lyrics.order(:position).each do |lyric| %>
      <div class="lyric-section border border-gray-200 rounded-lg overflow-hidden">
        <div class="bg-indigo-50 border-b border-indigo-100 px-4 py-2">
          <h3 class="text-xs font-semibold uppercase tracking-widest text-indigo-400">
            <%= localized_section_type(lyric.section_type) %>
          </h3>
        </div>
        <div class="bg-white px-4 py-3 text-lg leading-loose">
          <% content_lines = lyric.content.to_s.split("\n") %>
          <% pinyin_lines  = lyric.pinyin.to_s.split("\n") %>
          <% content_lines.each_with_index do |line, line_idx| %>
            <div class="mb-1">
              <% chars  = line.chars %>
              <% tokens = (pinyin_lines[line_idx] || "").split(" ") %>
              <% pinyin_idx = 0 %>
              <% chars.each do |char| %>
                <% if char.match?(/\p{Han}/) %>
                  <ruby><%= char %><rp>(</rp><rt><%= tokens[pinyin_idx] %></rt><rp>)</rp></ruby>
                  <% pinyin_idx += 1 %>
                <% else %>
                  <%= char %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

