<div class="p-6 bg-error-container/20 border-2 border-error/20 rounded-xl">
  <div class="flex items-start gap-3">
    <span class="material-symbols-outlined text-error">error</span>
    <div class="flex-1">
      <h3 class="font-headline text-lg text-on-surface mb-2">Song not found</h3>
      <p class="text-sm text-on-surface-variant font-body mb-4">
        Couldn't find "<%= title %>" in search results. Try:
      </p>
      <ul class="text-sm text-on-surface-variant font-body space-y-2 list-disc list-inside">
        <li>Adding the artist name: "Song Title - Artist Name"</li>
        <li>Checking the spelling</li>
        <li>Using the Chinese title if searching in English</li>
        <li>Pasting the lyrics manually instead</li>
      </ul>
      <div class="mt-4">
        <%= link_to "← Try again", songs_path, class: "inline-flex items-center gap-2 text-sm text-primary hover:underline font-medium" %>
      </div>
    </div>
  </div>
</div>
