<%
  generating_done  = step == "done"
  generating_active = step == "generating"
%>

<div class="bg-surface-container-lowest rounded-2xl shadow-ambient overflow-hidden"
     data-controller="<%= generating_active ? 'progress' : '' %>"
     data-progress-start-value="50"
     data-progress-end-value="<%= generating_done ? 100 : 90 %>"
     data-progress-duration-value="8000">
  
  <%# Animated top bar %>
  <div class="h-1 bg-surface-container-high relative overflow-hidden">
    <div class="h-full bg-gradient-to-r from-primary to-primary-container transition-all duration-700 ease-out
                <%= step == "generating" ? "w-1/2" : "w-full" %>"
         data-progress-target="bar"></div>
    
    <%# Shimmer effect while processing %>
    <% if generating_active %>
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent animate-shimmer"></div>
    <% end %>
  </div>

  <div class="p-6">
    <div class="flex items-center gap-4">
      <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0
                  <%= generating_done ? "bg-emerald-50" : generating_active ? "bg-primary/10 animate-pulse-slow" : "bg-surface-container" %>">
        <% if generating_done %>
          <span class="material-symbols-outlined text-emerald-600 text-base animate-scale-in" style="font-variation-settings:'FILL' 1">check_circle</span>
        <% elsif generating_active %>
          <div class="w-4 h-4 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
        <% else %>
          <span class="w-2 h-2 rounded-full bg-outline-variant/40 block"></span>
        <% end %>
      </div>
      <div class="flex-1">
        <p class="text-sm font-medium font-body <%= generating_active ? "text-on-surface" : generating_done ? "text-on-surface" : "text-on-surface-variant/40" %>">
          Generating Simplified Chinese + pinyin
        </p>
        <% if generating_active %>
          <p class="text-xs text-on-surface-variant font-body mt-0.5 animate-pulse-text">
            Claude is structuring your lyrics<span class="animate-dots">…</span>
          </p>
        <% elsif generating_done %>
          <p class="text-xs text-emerald-600 font-body mt-0.5 animate-fade-in">Done — redirecting…</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  
  @keyframes pulse-slow {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05); }
  }
  
  @keyframes pulse-text {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
  
  @keyframes scale-in {
    0% { transform: scale(0); }
    50% { transform: scale(1.2); }
    100% { transform: scale(1); }
  }
  
  @keyframes fade-in {
    0% { opacity: 0; }
    100% { opacity: 1; }
  }
  
  @keyframes dots {
    0%, 20% { content: ''; }
    40% { content: '.'; }
    60% { content: '..'; }
    80%, 100% { content: '...'; }
  }
  
  .animate-shimmer {
    animation: shimmer 2s infinite;
  }
  
  .animate-pulse-slow {
    animation: pulse-slow 2s ease-in-out infinite;
  }
  
  .animate-pulse-text {
    animation: pulse-text 2s ease-in-out infinite;
  }
  
  .animate-scale-in {
    animation: scale-in 0.4s ease-out;
  }
  
  .animate-fade-in {
    animation: fade-in 0.3s ease-out;
  }
  
  .animate-dots::after {
    content: '...';
    animation: dots 1.5s steps(4, end) infinite;
  }
</style>
