<div class="bg-surface-container rounded-xl p-6">
  <div class="flex items-center gap-3 mb-4">
    <div class="animate-spin h-5 w-5 border-2 border-primary border-t-transparent rounded-full"></div>
    <span class="text-sm font-medium text-on-surface font-body">Claude is structuring your lyrics...</span>
  </div>

  <div class="space-y-2">
    <%
      steps = [
        ["Searching for lyrics", %w[searching generating].include?(step)],
        ["Generating pinyin", step == "generating"]
      ]
    %>
    <% steps.each do |label, active| %>
      <div class="flex items-center gap-2 text-sm">
        <span class="<%= active ? 'text-primary' : 'text-on-surface-variant/40' %>">
          <%= active ? "✓" : "○" %>
        </span>
        <span class="<%= active ? 'text-on-surface font-medium' : 'text-on-surface-variant/40' %> font-body"><%= label %></span>
      </div>
    <% end %>
  </div>
</div>
