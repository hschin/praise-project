<div class="bg-white border border-gray-200 rounded-lg p-6">
  <div class="flex items-center gap-3 mb-4">
    <div class="animate-spin h-5 w-5 border-2 border-indigo-600 border-t-transparent rounded-full"></div>
    <span class="text-sm font-medium text-gray-700">Importing song...</span>
  </div>

  <div class="space-y-2">
    <%
      steps = [
        ["Searching web",    %w[processing done failed].include?(song.import_status)],
        ["Fetching lyrics",  song.import_step&.include?("Fetching") || song.import_step&.include?("Generating") || song.done? || song.failed?],
        ["Generating pinyin", song.import_step&.include?("Generating") || song.done? || song.failed?],
        ["Done",              song.done?]
      ]
    %>
    <% steps.each do |label, active| %>
      <div class="flex items-center gap-2 text-sm">
        <span class="<%= active ? 'text-indigo-600' : 'text-gray-400' %>">
          <%= active ? "✓" : "○" %>
        </span>
        <span class="<%= active ? 'text-gray-900 font-medium' : 'text-gray-400' %>"><%= label %></span>
      </div>
    <% end %>
  </div>

  <% if song.import_step.present? %>
    <p class="mt-3 text-xs text-gray-500 italic"><%= song.import_step %></p>
  <% end %>
</div>
