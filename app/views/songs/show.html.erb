<%= turbo_stream_from @song %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="font-headline text-3xl text-on-surface"><%= @song.title %></h1>
      <p class="text-sm text-on-surface-variant font-body mt-1">
        <% if @song.english_title.present? %>
          <span class="text-on-surface-variant/70"><%= @song.english_title %></span>
          <span class="mx-1 opacity-40">·</span>
        <% end %>
        <%= @song.artist.presence || "Unknown artist" %>
        <% if @song.default_key.present? %>
          <span class="mx-1 opacity-40">·</span>Key: <%= @song.default_key %>
        <% end %>
        <% if @song.ccli_number.present? %>
          <span class="mx-1 opacity-40">·</span>CCLI: <%= @song.ccli_number %>
        <% end %>
      </p>
      <% if @song.done? %>
        <p class="text-sm text-on-surface-variant mt-1 font-body">
          <%= link_to "Add this song to a deck →", decks_path, class: "text-primary hover:underline decoration-outline-variant" %>
        </p>
      <% end %>
    </div>
    <%= link_to "Back to Library", songs_path, class: "text-sm text-primary hover:underline decoration-outline-variant font-body" %>
  </div>

  <div id="song_status_<%= @song.id %>">
    <% if @song.done? %>
      <%= render "songs/lyrics", song: @song %>
    <% elsif @song.failed? %>
      <%= render "songs/failed", title: @song.title %>
    <% else %>
      <%= render "songs/processing", song: @song %>
    <% end %>
  </div>
</div>
