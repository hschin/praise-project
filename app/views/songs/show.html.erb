<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold"><%= @song.title %></h1>
    <p class="text-gray-500 text-sm mt-1"><%= @song.artist %> · Key of <%= @song.default_key.presence || "—" %></p>
  </div>
  <div class="flex gap-3">
    <%= link_to "Edit", edit_song_path(@song), class: "text-sm text-indigo-600 hover:underline" %>
    <%= link_to "Back", songs_path, class: "text-sm text-gray-500 hover:underline" %>
  </div>
</div>

<div class="space-y-4">
  <% if @song.lyrics.any? %>
    <% @song.lyrics.each do |lyric| %>
      <div class="bg-white border border-gray-200 rounded p-4">
        <p class="text-xs font-semibold text-indigo-500 uppercase tracking-wide mb-2"><%= lyric.section_type %></p>
        <% if lyric.pinyin.present? %>
          <p class="text-xs text-gray-400 mb-1 whitespace-pre-wrap"><%= lyric.pinyin %></p>
        <% end %>
        <p class="text-gray-900 whitespace-pre-wrap"><%= lyric.content %></p>
      </div>
    <% end %>
  <% else %>
    <p class="text-gray-500 text-sm">No lyrics yet.</p>
  <% end %>
</div>
