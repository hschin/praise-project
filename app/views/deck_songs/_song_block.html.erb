<%# locals: (deck:, deck_song:) %>
<div data-id="<%= deck_song.id %>"
     class="bg-surface-container-lowest border border-outline-variant/30 rounded-xl overflow-hidden shadow-sm">
  <div class="px-4 py-3 flex items-center justify-between border-b border-outline-variant/10 bg-surface-container-low/30">
    <div class="flex items-center gap-3">
      <span data-song-drag-handle class="cursor-grab text-outline/40 select-none material-symbols-outlined text-[20px]">drag_indicator</span>
      <div>
        <p class="font-headline font-bold text-on-surface"><%= deck_song.song.title %></p>
        <p class="text-xs text-on-surface-variant font-body">
          <%= deck_song.song.artist.presence || "—" %> &middot;
          Key: <%= deck_song.key.presence || deck_song.song.default_key || "—" %>
        </p>
      </div>
    </div>
    <div class="flex items-center gap-1">
      <%= link_to edit_song_path(deck_song.song),
          target: "_blank",
          title: "Edit lyrics",
          class: "p-1.5 rounded-lg text-outline hover:text-primary hover:bg-surface-container transition-colors" do %>
        <span class="material-symbols-outlined text-[18px]">edit</span>
      <% end %>
      <%= button_to deck_deck_song_path(deck, deck_song),
          method: :delete,
          title: "Remove from deck",
          data: { turbo_confirm: "Remove #{deck_song.song.title} from this deck?" },
          class: "p-1.5 rounded-lg text-outline hover:text-error hover:bg-surface-container transition-colors bg-transparent border-0 cursor-pointer" do %>
        <span class="material-symbols-outlined text-[18px]">remove_circle</span>
      <% end %>
    </div>
  </div>

  <% if deck_song.arrangement&.any? %>
    <div data-controller="sortable"
         data-sortable-url-value="<%= update_arrangement_deck_deck_song_path(deck, deck_song) %>"
         data-sortable-param-value="arrangement"
         data-sortable-group-value="slides"
         class="divide-y divide-outline-variant/10 p-2 space-y-1 ml-4 border-l-2 border-outline-variant/20 my-1">
      <% deck_song.arrangement.each_with_index do |lyric_id, idx| %>
        <% lyric = Lyric.find_by(id: lyric_id) %>
        <% next if lyric.nil? %>
        <%= render "deck_songs/slide_item",
            deck_song: deck_song,
            lyric: lyric,
            arrangement_index: idx %>
      <% end %>
    </div>
  <% else %>
    <p class="text-xs text-on-surface-variant/60 px-4 py-3 font-body">No slides in arrangement.</p>
  <% end %>
</div>
