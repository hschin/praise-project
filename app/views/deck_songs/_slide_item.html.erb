<%# locals: (deck_song:, lyric:, arrangement_index:) %>
<% new_arrangement_without = deck_song.arrangement.dup.tap { |a| a.delete_at(arrangement_index) } %>
<% new_arrangement_repeat = deck_song.arrangement.dup.insert(arrangement_index + 1, lyric.id) %>

<div data-id="<%= lyric.id %>"
     class="bg-surface-container-lowest border border-outline-variant/20 rounded-lg p-3 flex items-start gap-3 cursor-default">
  <span data-drag-handle class="cursor-grab text-outline/30 select-none material-symbols-outlined text-[18px] mt-0.5">drag_indicator</span>
  <div class="flex-1 min-w-0">
    <%
      chip_classes = case lyric.section_type.to_s.downcase
        when "verse"      then "bg-tertiary-fixed/30 text-tertiary"
        when "chorus"     then "bg-primary-fixed/30 text-primary"
        when "bridge"     then "bg-surface-container-highest text-on-surface-variant"
        when "pre-chorus" then "bg-secondary-fixed/30 text-secondary"
        else "bg-surface-container text-on-surface-variant"
      end
    %>
    <span class="inline-block text-xs font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full mb-1 font-label <%= chip_classes %>">
      <%= localized_section_type(lyric.section_type) %>
    </span>
    <p class="text-sm text-on-surface truncate font-body"><%= lyric.content.to_s.lines.first&.strip %></p>
  </div>
  <div class="flex items-center gap-2 shrink-0">
    <%= button_to "+ Repeat",
        update_arrangement_deck_deck_song_path(deck_song.deck, deck_song),
        method: :patch,
        params: { arrangement: new_arrangement_repeat },
        class: "text-xs text-secondary bg-secondary/5 hover:bg-secondary/10 bg-transparent border-0 cursor-pointer px-1 font-label" %>
    <%= button_to "Remove",
        update_arrangement_deck_deck_song_path(deck_song.deck, deck_song),
        method: :patch,
        params: { arrangement: new_arrangement_without },
        data: { turbo_confirm: "Remove this slide from the arrangement?" },
        class: "text-xs text-error hover:bg-error-container bg-transparent border-0 cursor-pointer px-1 rounded font-label" %>
  </div>
</div>
