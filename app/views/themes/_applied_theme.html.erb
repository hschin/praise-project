<%# locals: (theme:, deck:) %>
<div class="flex items-center gap-4 p-3 bg-stone-50 rounded-lg border border-stone-200">
  <div class="flex items-center gap-2">
    <div class="w-6 h-6 rounded-lg border border-stone-200 shrink-0"
         style="background-color: <%= theme.background_color %>;" title="Background"></div>
    <div class="w-6 h-6 rounded-lg border border-stone-200 shrink-0"
         style="background-color: <%= theme.text_color %>;" title="Text color"></div>
  </div>
  <div class="flex-1 min-w-0">
    <p class="text-sm font-medium text-stone-900 truncate"><%= theme.name %></p>
    <p class="text-xs text-stone-500">
      <%= theme.source.capitalize %> ·
      Font: <%= theme.font_size %>
      <% if theme.background_image.attached? %>
        · Custom background image
      <% end %>
    </p>
  </div>
  <p class="text-xs text-stone-400 italic">Applied</p>
</div>
