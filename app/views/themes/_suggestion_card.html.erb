<%# locals: (suggestion:, deck:) %>
<div class="shrink-0 w-40 rounded-lg overflow-hidden border border-stone-200 shadow-sm hover:shadow-md transition-shadow">
  <%# Unsplash thumbnail or color swatch %>
  <% if suggestion["unsplash_url"].present? %>
    <img src="<%= suggestion["unsplash_url"] %>"
         alt="<%= suggestion["name"] %> background"
         class="w-full h-20 object-cover"
         loading="lazy">
  <% else %>
    <div class="w-full h-20"
         style="background-color: <%= suggestion["background_color"] %>;"></div>
  <% end %>

  <div class="p-2">
    <p class="text-xs font-semibold text-stone-800 truncate mb-1"><%= suggestion["name"] %></p>

    <%# Color swatches %>
    <div class="flex gap-1 mb-2">
      <div class="w-4 h-4 rounded-full border border-stone-200"
           style="background-color: <%= suggestion["background_color"] %>;"
           title="Background: <%= suggestion["background_color"] %>"></div>
      <div class="w-4 h-4 rounded-full border border-stone-200"
           style="background-color: <%= suggestion["text_color"] %>;"
           title="Text: <%= suggestion["text_color"] %>"></div>
      <span class="text-xs text-stone-400 ml-1"><%= suggestion["font_size"] %></span>
    </div>

    <%# Apply button — posts to ThemesController#create with pre-filled params %>
    <%= button_to "Apply",
        deck_themes_path(deck),
        method: :post,
        params: {
          theme: {
            name:             suggestion["name"],
            source:           "ai",
            background_color: suggestion["background_color"],
            text_color:       suggestion["text_color"],
            font_size:        suggestion["font_size"],
            unsplash_url:     suggestion["unsplash_url"]
          }
        },
        class: "w-full text-xs bg-rose-700 text-white py-1 rounded-lg hover:bg-rose-800 cursor-pointer" %>

    <%# Unsplash attribution (required by Unsplash API terms) %>
    <% if suggestion["unsplash_attribution_url"].present? %>
      <p class="text-xs text-stone-400 mt-1 leading-tight">
        Photo:
        <a href="<%= suggestion["unsplash_attribution_url"] %>?utm_source=praiseproject&utm_medium=referral"
           target="_blank"
           rel="noopener"
           class="hover:underline">
          <%= suggestion["unsplash_attribution_name"] %>
        </a> / Unsplash
      </p>
    <% end %>
  </div>
</div>
