<% is_success = type == :notice %>
<% bg_class    = is_success ? "bg-secondary-container" : "bg-error-container" %>
<% text_class  = is_success ? "text-on-secondary-container" : "text-on-error-container" %>

<div data-controller="flash"
     data-flash-auto-dismiss-value="<%= is_success ? 'true' : 'false' %>"
     data-flash-delay-value="4000"
     class="w-80 rounded-lg shadow-md px-4 py-3 flex items-start gap-3 pointer-events-auto
            transition-all duration-300 translate-x-full opacity-0
            <%= bg_class %>">

  <% if is_success %>
    <span class="material-symbols-outlined text-xl flex-shrink-0 <%= text_class %>">check_circle</span>
  <% else %>
    <span class="material-symbols-outlined text-xl flex-shrink-0 <%= text_class %>">warning</span>
  <% end %>

  <p class="text-sm flex-1 <%= text_class %>"><%= message %></p>

  <% unless is_success %>
    <button type="button"
            data-action="click->flash#dismiss"
            class="<%= text_class %> opacity-60 hover:opacity-100 flex-shrink-0 ml-auto transition-opacity">
      <span class="material-symbols-outlined text-base">close</span>
    </button>
  <% end %>
</div>
