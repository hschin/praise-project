<% is_success = type == :notice %>

<div data-controller="flash"
     data-flash-auto-dismiss-value="<%= is_success ? 'true' : 'false' %>"
     data-flash-delay-value="4000"
     class="relative w-96 bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_10px_40px_rgba(31,27,23,0.10)] pointer-events-auto
            transition-all duration-300 translate-x-full opacity-0">

  <div class="flex items-start p-5 gap-4">
    <%# Icon badge %>
    <% if is_success %>
      <div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center flex-shrink-0 animate-scale-in">
        <span class="material-symbols-outlined text-emerald-700 text-xl" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;">check_circle</span>
      </div>
    <% else %>
      <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0 animate-scale-in">
        <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;">warning</span>
      </div>
    <% end %>

    <%# Message %>
    <div class="flex-1 pr-6 min-w-0">
      <p class="font-headline text-lg leading-snug <%= is_success ? 'text-on-surface' : 'text-primary' %>"><%= message %></p>
    </div>

    <%# Close button — both success and error %>
    <button type="button"
            data-action="click->flash#dismiss"
            class="absolute top-4 right-4 text-on-surface-variant/40 hover:text-on-surface transition-colors flex-shrink-0">
      <span class="material-symbols-outlined text-base">close</span>
    </button>
  </div>

  <%# Accent bar with countdown animation %>
  <% if is_success %>
    <div class="h-1 w-full bg-emerald-500/10 overflow-hidden">
      <div class="h-full bg-emerald-500 w-full opacity-60 animate-countdown"></div>
    </div>
  <% else %>
    <div class="h-1 w-full bg-primary/10">
      <div class="h-full bg-primary w-full opacity-60"></div>
    </div>
  <% end %>
</div>

<style>
  @keyframes scale-in {
    0% { transform: scale(0); opacity: 0; }
    50% { transform: scale(1.15); }
    100% { transform: scale(1); opacity: 1; }
  }
  
  @keyframes countdown {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }
  
  .animate-scale-in {
    animation: scale-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  
  .animate-countdown {
    animation: countdown 4s linear forwards;
  }
</style>
