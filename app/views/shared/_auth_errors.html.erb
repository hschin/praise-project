<% if resource.errors.any? %>
  <div data-controller="flash"
       data-flash-auto-dismiss-value="false"
       data-turbo-temporary
       class="fixed top-[80px] right-4 z-50 w-80 rounded-lg shadow-md px-4 py-3 flex items-start gap-3
              transition-all duration-300 translate-x-full opacity-0
              bg-error-container text-on-error-container">
    <span class="material-symbols-outlined text-[20px] flex-shrink-0 mt-0.5">warning</span>
    <div class="flex-1 text-sm space-y-0.5">
      <% resource.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
    <button type="button"
            data-action="click->flash#dismiss"
            class="text-on-error-container/60 hover:text-on-error-container flex-shrink-0 ml-auto">
      <span class="material-symbols-outlined text-[18px]">close</span>
    </button>
  </div>
<% end %>
