<%# locals: (deck:) %>
<% slide_number = 0 %>
<% if deck.deck_songs.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% deck.deck_songs.each do |deck_song| %>
      <% slides = (deck_song.arrangement || []).filter_map { |id| Lyric.find_by(id: id) } %>
      <% next if slides.empty? %>
      <% slides.each do |lyric| %>
        <% slide_number += 1 %>
        <div class="group relative">
          <div class="slide-preview aspect-video rounded-xl overflow-hidden shadow-lg border-2 border-transparent hover:border-primary transition-all relative"
               style="container-type: inline-size; background-color: <%= deck.theme&.background_color.presence || '#1a1a2e' %>;<%= deck.theme&.background_image&.attached? ? "background-image: url('#{url_for(deck.theme.background_image)}'); background-size: cover; background-position: center;" : deck.theme&.unsplash_url.present? ? "background-image: url('#{deck.theme.unsplash_url}'); background-size: cover; background-position: center;" : "" %>">
            <div class="absolute inset-0 flex items-center justify-center" style="padding: 4cqw;">
              <% font_cqw = { "small" => "2.8", "large" => "4.5" }.fetch(deck.theme&.font_size.to_s, "3.5") %>
              <div class="text-center" style="color: <%= deck.theme&.text_color.presence || '#ffffff' %>; font-size: <%= font_cqw %>cqw; line-height: 1.8;">
                <% lyric.content.to_s.split("\n").each_with_index do |line, li| %>
                  <% pinyin_line = lyric.pinyin.to_s.split("\n")[li] || "" %>
                  <div>
                    <% chars = line.chars %>
                    <% tokens = pinyin_line.split(" ") %>
                    <% pi = 0 %>
                    <% chars.each do |char| %>
                      <% if char.match?(/\p{Han}/) %>
                        <ruby><%= char %><rt style="font-size:0.6em"><%= tokens[pi] %></rt></ruby><% pi += 1 %>
                      <% else %><%= char %><% end %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
            <div class="absolute bottom-0 right-0 opacity-40" style="font-size: 1.8cqw; padding: 1cqw 2cqw; color: <%= deck.theme&.text_color.presence || '#ffffff' %>;">
              <%= lyric.section_type %>
            </div>
          </div>
          <%# Slide number badge %>
          <span class="absolute top-3 left-3 bg-black/40 text-white text-[10px] font-label px-2 py-0.5 rounded-full backdrop-blur-sm"><%= slide_number %></span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="flex items-center justify-center h-48 rounded-lg border-2 border-dashed border-outline-variant/40">
    <p class="text-sm text-on-surface-variant/60 font-body">Add songs to see slide previews.</p>
  </div>
<% end %>
