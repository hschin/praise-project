<%= form_with model: deck, class: "space-y-4" do |f| %>
  <% if deck.errors.any? %>
    <div class="bg-error-container text-on-error-container text-sm rounded-lg p-4">
      <% deck.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Title", class: "block text-[0.75rem] font-semibold uppercase tracking-wider text-on-surface-variant font-label mb-1" %>
    <%= f.text_field :title, class: "w-full bg-surface-container-lowest border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary text-on-surface font-body #{deck.errors[:title].any? ? 'border-primary focus:ring-primary' : 'border-outline-variant/30'}" %>
    <% if deck.errors[:title].any? %>
      <p class="mt-1 text-xs text-primary font-body"><%= deck.errors[:title].first %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :date, "Date", class: "block text-[0.75rem] font-semibold uppercase tracking-wider text-on-surface-variant font-label mb-1" %>
    <%= f.date_field :date, class: "w-full bg-surface-container-lowest border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary text-on-surface font-body #{deck.errors[:date].any? ? 'border-primary focus:ring-primary' : 'border-outline-variant/30'}" %>
    <% if deck.errors[:date].any? %>
      <p class="mt-1 text-xs text-primary font-body"><%= deck.errors[:date].first %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :notes, "Notes", class: "block text-[0.75rem] font-semibold uppercase tracking-wider text-on-surface-variant font-label mb-1" %>
    <%= f.text_area :notes, rows: 3, class: "w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary text-on-surface font-body" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit class: "bg-gradient-to-r from-primary to-primary-container text-on-primary text-sm px-4 py-2 rounded-lg font-medium hover:opacity-95 active:scale-[0.98] transition-all cursor-pointer" %>
    <%= link_to "Cancel", decks_path, class: "text-sm text-on-surface-variant hover:text-primary transition-colors self-center font-body" %>
  </div>
<% end %>
