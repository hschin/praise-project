<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold"><%= @deck.title %></h1>
    <p class="text-sm text-gray-500 mt-1"><%= @deck.date.strftime("%A, %d %B %Y") %></p>
  </div>
  <div class="flex gap-3">
    <%= button_to "Export PPTX", export_deck_path(@deck), method: :post, class: "bg-indigo-600 text-white text-sm px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Edit", edit_deck_path(@deck), class: "text-sm text-indigo-600 hover:underline" %>
    <%= link_to "Back", decks_path, class: "text-sm text-gray-500 hover:underline" %>
  </div>
</div>

<% if @deck.notes.present? %>
  <p class="text-sm text-gray-600 mb-6"><%= @deck.notes %></p>
<% end %>

<div class="space-y-3">
  <% if @deck.deck_songs.any? %>
    <% @deck.deck_songs.each do |deck_song| %>
      <div class="bg-white border border-gray-200 rounded p-4 flex items-center justify-between">
        <div>
          <p class="font-medium"><%= deck_song.song.title %></p>
          <p class="text-sm text-gray-500"><%= deck_song.song.artist %> · Key: <%= deck_song.key.presence || deck_song.song.default_key || "—" %></p>
        </div>
        <%= button_to "Remove", deck_deck_song_path(@deck, deck_song), method: :delete, data: { turbo_confirm: "Remove this song from the deck?" }, class: "text-red-500 text-sm hover:underline bg-transparent border-0 cursor-pointer" %>
      </div>
    <% end %>
  <% else %>
    <p class="text-gray-500 text-sm">No songs added yet.</p>
  <% end %>
</div>

<div class="mt-8 border-t pt-6">
  <h2 class="text-sm font-semibold text-gray-700 mb-3">Add a Song</h2>
  <%= form_with url: deck_deck_songs_path(@deck), class: "flex gap-3" do |f| %>
    <%= f.select :song_id, Song.order(:title).map { |s| [s.title, s.id] },
        { include_blank: "Select a song..." },
        class: "flex-1 border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    <%= f.submit "Add", class: "bg-indigo-600 text-white text-sm px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
  <% end %>
</div>
