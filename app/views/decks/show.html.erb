<% content_for :main_class, 'w-full px-6 py-8' %>
<div>

  <%# Header — full width %>
  <div class="flex items-center justify-between mb-6">
    <div class="group" data-controller="inline-edit"
         data-inline-edit-url-value="<%= deck_path(@deck) %>">
      <div class="flex items-center gap-2">
        <span data-inline-edit-target="display"
              class="text-2xl font-semibold leading-snug text-stone-900">
          <%= @deck.title %>
        </span>
        <button data-action="click->inline-edit#edit"
                class="text-stone-400 hover:text-rose-700"
                aria-label="Edit title">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
            <path d="M11.013 2.513a1.75 1.75 0 0 1 2.475 2.474L6.226 12.25a2.751 2.751 0 0 1-.892.596l-2.047.848a.75.75 0 0 1-.98-.98l.848-2.047a2.75 2.75 0 0 1 .596-.892l7.262-7.262Z"/>
          </svg>
        </button>
      </div>
      <input data-inline-edit-target="input"
             hidden
             type="text"
             value="<%= @deck.title %>"
             data-action="blur->inline-edit#save keydown.enter->inline-edit#save keydown.escape->inline-edit#cancel"
             class="text-2xl font-semibold leading-snug text-stone-900 border-b-2 border-rose-600 focus:outline-none bg-transparent w-full mt-0">
      <div class="flex items-center gap-1 mt-1"
           data-controller="inline-edit"
           data-inline-edit-url-value="<%= deck_path(@deck) %>"
           data-inline-edit-field-value="date">
        <span data-inline-edit-target="display" class="text-sm text-stone-500">
          <%= @deck.date.strftime("%A, %d %B %Y") %>
        </span>
        <button data-action="click->inline-edit#edit"
                class="text-stone-300 hover:text-rose-700"
                aria-label="Edit date">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3">
            <path d="M11.013 2.513a1.75 1.75 0 0 1 2.475 2.474L6.226 12.25a2.751 2.751 0 0 1-.892.596l-2.047.848a.75.75 0 0 1-.98-.98l.848-2.047a2.75 2.75 0 0 1 .596-.892l7.262-7.262Z"/>
          </svg>
        </button>
        <input data-inline-edit-target="input"
               hidden
               type="date"
               value="<%= @deck.date.iso8601 %>"
               data-action="blur->inline-edit#save keydown.escape->inline-edit#cancel"
               class="text-sm text-stone-500 border-b border-rose-600 focus:outline-none bg-transparent">
      </div>

      <div class="flex items-start gap-1 mt-1"
           data-controller="inline-edit"
           data-inline-edit-url-value="<%= deck_path(@deck) %>"
           data-inline-edit-field-value="notes"
           data-inline-edit-allow-empty-value="true">
        <span data-inline-edit-target="display" class="text-sm text-stone-600">
          <%= @deck.notes.presence || "Add notes…" %>
        </span>
        <button data-action="click->inline-edit#edit"
                class="text-stone-300 hover:text-rose-700 mt-0.5 flex-shrink-0"
                aria-label="Edit notes">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3">
            <path d="M11.013 2.513a1.75 1.75 0 0 1 2.475 2.474L6.226 12.25a2.751 2.751 0 0 1-.892.596l-2.047.848a.75.75 0 0 1-.98-.98l.848-2.047a2.75 2.75 0 0 1 .596-.892l7.262-7.262Z"/>
          </svg>
        </button>
        <textarea data-inline-edit-target="input"
                  hidden
                  rows="2"
                  data-action="blur->inline-edit#save keydown.escape->inline-edit#cancel"
                  class="text-sm text-stone-600 border-b border-rose-600 focus:outline-none bg-transparent w-full resize-none"><%= @deck.notes %></textarea>
      </div>
    </div>
    <div class="flex gap-3 items-center">
      <%= render "decks/export_button", deck: @deck, state: :idle %>
<%= link_to "Back", decks_path, class: "text-sm text-stone-500 hover:underline" %>
    </div>
  </div>

  <%# 3-column editor layout %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 items-start">

    <%# LEFT — Song & slide arrangement %>
    <div class="md:col-span-1 lg:col-span-3 space-y-4">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-stone-400">Arrangement</h2>

      <%# Sortable song list %>
      <div data-controller="sortable"
           data-sortable-url-value="<%= reorder_deck_deck_song_path(@deck, ':id') %>"
           class="space-y-3">
        <% if @deck.deck_songs.any? %>
          <% @deck.deck_songs.each do |deck_song| %>
            <%= render "deck_songs/song_block", deck: @deck, deck_song: deck_song %>
          <% end %>
        <% else %>
          <p class="text-stone-400 text-sm">No songs added yet.</p>
        <% end %>
      </div>

      <%# Add Song — search library or import new %>
      <div class="pt-3 border-t border-stone-100 space-y-3" data-controller="song-search">
        <p class="text-xs font-semibold text-stone-500">Add a song</p>

        <%# Filter existing library %>
        <input type="text"
               placeholder="Search library..."
               data-song-search-target="input"
               data-action="input->song-search#filter"
               class="w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-600">

        <div class="max-h-52 overflow-y-auto space-y-1">
          <% library_songs = Song.where(import_status: "done").order(:title) %>
          <% library_songs.each do |song| %>
            <div data-song-search-target="item" data-title="<%= song.title %>">
              <%= form_with url: deck_deck_songs_path(@deck) do |f| %>
                <%= f.hidden_field :song_id, value: song.id %>
                <button type="submit" class="w-full text-left px-2 py-1.5 rounded-lg text-sm hover:bg-rose-50 flex items-center justify-between group">
                  <span class="truncate text-stone-800"><%= song.title %></span>
                  <span class="text-rose-700 text-xs opacity-0 group-hover:opacity-100 shrink-0 ml-2">+ Add</span>
                </button>
              <% end %>
            </div>
          <% end %>
          <% if library_songs.empty? %>
            <p class="text-xs text-stone-400 px-2 py-1">No songs in library yet.</p>
          <% end %>
          <p data-song-search-target="empty" hidden class="text-xs text-stone-400 px-2 py-1">No matches.</p>
        </div>

        <%# Import a new song — shown inline when search has no library matches %>
        <div data-song-search-target="importSection" hidden class="border-t border-stone-100 pt-3 space-y-2">
          <p class="text-xs text-stone-500">Not in library — import from web:</p>
          <%= form_with url: import_songs_path, method: :post, data: { turbo: false }, class: "flex gap-2" do |f| %>
            <%= hidden_field_tag :deck_id, @deck.id %>
            <%= f.text_field :title,
                  placeholder: "Song title...",
                  data: { "song-search-target": "importTitle" },
                  class: "flex-1 min-w-0 border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-600" %>
            <%= f.submit "Import", class: "bg-rose-700 text-white text-sm px-3 py-2 rounded-lg hover:bg-rose-800 cursor-pointer shrink-0" %>
          <% end %>
          <details class="text-xs">
            <summary class="cursor-pointer text-stone-400 hover:text-stone-600">Paste lyrics manually</summary>
            <div class="mt-2">
              <%= form_with url: import_songs_path, method: :post, data: { turbo: false }, class: "space-y-2" do |f| %>
                <%= hidden_field_tag :deck_id, @deck.id %>
                <%= f.text_field :title,
                      placeholder: "Song title",
                      data: { "song-search-target": "importTitle" },
                      class: "w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-600" %>
                <%= f.text_area :raw_lyrics, placeholder: "Paste raw lyrics here...", rows: 5, class: "w-full border border-stone-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-600" %>
                <%= f.submit "Import Pasted Lyrics", class: "w-full bg-stone-700 text-white text-sm px-3 py-2 rounded-lg hover:bg-stone-800 cursor-pointer" %>
              <% end %>
            </div>
          </details>
        </div>
      </div>
    </div>

    <%# MIDDLE — Slide preview %>
    <div class="md:col-span-1 lg:col-span-6" id="slide_preview_section">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-stone-400 mb-4">Slide Preview <span class="normal-case font-normal text-stone-300 ml-1">— approximate</span></h2>
      <% if @deck.deck_songs.any? %>
        <div class="space-y-6">
          <% @deck.deck_songs.each do |deck_song| %>
            <% slides = (deck_song.arrangement || []).filter_map { |id| Lyric.find_by(id: id) } %>
            <% next if slides.empty? %>
            <div>
              <p class="text-xs text-stone-400 mb-2"><%= deck_song.song.title %></p>
              <div class="grid grid-cols-2 gap-3">
                <% slides.each do |lyric| %>
                  <div class="slide-preview rounded-lg shadow-sm overflow-hidden relative w-full"
                       style="aspect-ratio: 16/9; container-type: inline-size; background-color: <%= @deck.theme&.background_color.presence || '#1a1a2e' %>;<%= @deck.theme&.background_image&.attached? ? "background-image: url('#{url_for(@deck.theme.background_image)}'); background-size: cover; background-position: center;" : "" %>">
                    <div class="absolute inset-0 flex items-center justify-center" style="padding: 4cqw;">
                      <% font_cqw = { "small" => "2.8", "large" => "4.5" }.fetch(@deck.theme&.font_size.to_s, "3.5") %>
                      <div class="text-center" style="color: <%= @deck.theme&.text_color.presence || '#ffffff' %>; font-size: <%= font_cqw %>cqw; line-height: 1.8;">
                        <% lyric.content.to_s.split("\n").each_with_index do |line, li| %>
                          <% pinyin_line = lyric.pinyin.to_s.split("\n")[li] || "" %>
                          <div>
                            <% chars = line.chars %>
                            <% tokens = pinyin_line.split(" ") %>
                            <% pi = 0 %>
                            <% chars.each do |char| %>
                              <% if char.match?(/\p{Han}/) %>
                                <ruby><%= char %><rt style="font-size:0.6em"><%= tokens[pi] %></rt></ruby><% pi += 1 %>
                              <% else %><%= char %><% end %>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                    <div class="absolute bottom-0 right-0 opacity-40" style="font-size: 1.8cqw; padding: 1cqw 2cqw; color: <%= @deck.theme&.text_color.presence || '#ffffff' %>;">
                      <%= lyric.section_type %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex items-center justify-center h-48 rounded-lg border-2 border-dashed border-stone-200">
          <p class="text-sm text-stone-400">Add songs to see slide previews.</p>
        </div>
      <% end %>
    </div>

    <%# RIGHT — Theme %>
    <div class="md:col-span-2 lg:col-span-3" id="theme_section">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-stone-400 mb-4">Theme</h2>

      <%= turbo_stream_from "deck_export_#{@deck.id}" %>
      <%= turbo_stream_from "deck_themes_#{@deck.id}" %>

      <% if @deck.theme.present? %>
        <%= render "themes/applied_theme", theme: @deck.theme, deck: @deck %>
        <details class="mt-4">
          <summary class="text-xs text-rose-700 cursor-pointer hover:underline">Change theme</summary>
          <div class="mt-3">
            <%= render "themes/form", deck: @deck %>
          </div>
        </details>
      <% else %>
        <%= render "themes/form", deck: @deck %>
      <% end %>

      <%# AI suggestions %>
      <div class="mt-4 pt-4 border-t border-stone-100">
        <%= button_to "✦ Get AI Suggestions",
            suggest_deck_themes_path(@deck),
            method: :post,
            class: "w-full text-sm bg-white border border-rose-300 text-rose-700 px-3 py-2 rounded-lg hover:bg-rose-50 cursor-pointer" %>
        <p class="text-xs text-stone-400 mt-1 text-center">Claude suggests 5 themes with worship photography.</p>
      </div>

      <div id="theme_suggestions" class="mt-4"></div>
    </div>

  </div>
</div>
