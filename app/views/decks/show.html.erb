<% content_for :main_class, 'w-full p-0' %>

<%# Deck header — full width %>
<div class="px-8 py-6 border-b border-outline-variant/20 flex flex-col md:flex-row md:items-end justify-between gap-6">
  <div class="flex-1 space-y-2">
    <%= link_to decks_path, class: "inline-flex items-center gap-1 text-xs text-on-surface-variant hover:text-primary transition-colors font-body mb-2" do %>
      <span class="material-symbols-outlined text-[14px]">arrow_back</span>
      All decks
    <% end %>
    <div class="group" data-controller="inline-edit"
         data-inline-edit-url-value="<%= deck_path(@deck) %>">
      <div class="flex items-center gap-2">
        <span data-inline-edit-target="display"
              class="font-headline text-4xl text-on-surface leading-snug">
          <%= @deck.title %>
        </span>
        <button data-action="click->inline-edit#edit"
                class="text-outline opacity-0 group-hover:opacity-100 transition-opacity hover:text-primary"
                aria-label="Edit title">
          <span class="material-symbols-outlined text-base">edit</span>
        </button>
      </div>
      <input data-inline-edit-target="input"
             hidden
             type="text"
             value="<%= @deck.title %>"
             data-action="blur->inline-edit#save keydown.enter->inline-edit#save keydown.escape->inline-edit#cancel"
             class="font-headline text-4xl text-on-surface border-b-2 border-primary focus:outline-none bg-transparent w-full mt-0">

      <div class="flex flex-wrap items-center gap-6 text-on-surface-variant mt-2">
        <div class="flex items-center gap-1"
             data-controller="inline-edit"
             data-inline-edit-url-value="<%= deck_path(@deck) %>"
             data-inline-edit-field-value="date">
          <span class="material-symbols-outlined text-sm">calendar_today</span>
          <span data-inline-edit-target="display" class="text-sm font-body">
            <%= @deck.date.strftime("%A, %d %B %Y") %>
          </span>
          <button data-action="click->inline-edit#edit"
                  class="text-outline/40 hover:text-primary"
                  aria-label="Edit date">
            <span class="material-symbols-outlined text-sm">edit</span>
          </button>
          <input data-inline-edit-target="input"
                 hidden
                 type="date"
                 data-action="blur->inline-edit#save keydown.escape->inline-edit#cancel"
                 class="text-sm text-on-surface-variant border-b border-primary focus:outline-none bg-transparent font-body">
        </div>

        <div class="flex items-center gap-1"
             data-controller="inline-edit"
             data-inline-edit-url-value="<%= deck_path(@deck) %>"
             data-inline-edit-field-value="notes"
             data-inline-edit-allow-empty-value="true">
          <span class="material-symbols-outlined text-sm">notes</span>
          <span data-inline-edit-target="display" class="text-sm font-body">
            <%= @deck.notes.presence || "Add rehearsal notes…" %>
          </span>
          <button data-action="click->inline-edit#edit"
                  class="text-outline/40 hover:text-primary flex-shrink-0"
                  aria-label="Edit notes">
            <span class="material-symbols-outlined text-sm">edit</span>
          </button>
          <textarea data-inline-edit-target="input"
                    hidden
                    rows="2"
                    data-action="blur->inline-edit#save keydown.escape->inline-edit#cancel"
                    class="text-sm text-on-surface-variant border-b border-primary focus:outline-none bg-transparent w-64 resize-none font-body"><%= @deck.notes %></textarea>
        </div>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= render "decks/export_button", deck: @deck, state: :idle %>
  </div>
</div>

<%# 3-column editor layout — full height panels %>
<div class="grid grid-cols-1 lg:grid-cols-12 min-h-[calc(100vh-144px)]">

  <%# LEFT — Arrangement + Add Songs %>
  <aside class="lg:col-span-3 bg-surface-container-low border-r border-outline-variant/10 p-6 flex flex-col gap-8 overflow-y-auto lg:max-h-[calc(100vh-144px)]">

    <%# Arrangement section %>
    <section class="space-y-4" data-controller="auto-save"
             data-action="turbo:submit-end->auto-save#show">
      <div class="flex items-center justify-between">
        <h3 class="font-headline text-xl text-on-surface">Arrangement</h3>
        <div class="flex items-center gap-2">
          <span data-auto-save-target="indicator"
                class="text-xs text-on-surface-variant/60 font-body opacity-0 transition-opacity duration-300">Saved</span>
          <span class="text-xs font-label uppercase tracking-widest text-outline">
            <%= @deck.deck_songs.count %> <%= @deck.deck_songs.count == 1 ? "Song" : "Songs" %>
          </span>
        </div>
      </div>

      <div id="deck_songs_section">
        <%= render "decks/song_list", deck: @deck %>
      </div>
    </section>

    <%# Add Songs section %>
    <section class="space-y-4 pt-6 border-t border-outline-variant/20" data-controller="song-search">
      <h3 class="font-headline text-xl text-on-surface">Add Songs</h3>

      <%# Search with icon %>
      <div class="relative">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">search</span>
        <input type="text"
               placeholder="Search library..."
               data-song-search-target="input"
               data-action="input->song-search#filter"
               class="w-full pl-10 pr-4 py-2.5 bg-surface-container-highest border-none rounded-xl focus:ring-2 focus:ring-primary/20 text-sm font-body text-on-surface placeholder:text-outline">
      </div>

      <div class="space-y-1">
        <% already_added_ids = @deck.deck_songs.pluck(:song_id) %>
        <% available_songs = Song.where(import_status: "done").where.not(id: already_added_ids) %>
        <% library_songs = available_songs.order(:title) %>
        <% suggested_ids = available_songs.order(Arel.sql("RANDOM()")).limit(5).pluck(:id).to_set %>
        <% library_songs.each do |song| %>
          <div data-song-search-target="item"
               data-title="<%= song.title %>"
               data-english-title="<%= song.english_title %>"
               data-artist="<%= song.artist %>"
               data-suggested="<%= suggested_ids.include?(song.id) %>"
               <%= suggested_ids.include?(song.id) ? "" : 'hidden' %>>
            <%= form_with url: deck_deck_songs_path(@deck), data: { controller: "add-song" } do |f| %>
              <%= f.hidden_field :song_id, value: song.id %>
              <button type="submit"
                      data-add-song-target="button"
                      data-action="click->add-song#loading"
                      class="w-full text-left px-3 py-2 rounded-lg hover:bg-surface-container-high transition-colors flex items-center justify-between group">
                <div>
                  <p class="text-sm font-medium text-on-surface font-body"><%= song.title %></p>
                  <div class="flex flex-wrap gap-x-2 mt-0.5">
                    <% if song.artist.present? %>
                      <p class="text-[10px] text-outline font-body"><%= song.artist %></p>
                    <% end %>
                    <% if song.english_title.present? %>
                      <p class="text-[10px] text-outline/70 font-body italic"><%= song.english_title %></p>
                    <% end %>
                    <% if song.default_key.present? %>
                      <p class="text-[10px] text-outline/70 font-body">Key: <%= song.default_key %></p>
                    <% end %>
                  </div>
                </div>
                <span data-add-song-target="label" class="text-xs border border-primary text-primary px-3 py-1 rounded-lg font-label shrink-0 ml-2 group-hover:bg-primary group-hover:text-on-primary transition-colors">+ Add</span>
                <span data-add-song-target="spinner" hidden class="shrink-0 ml-2">
                  <svg class="animate-spin h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                  </svg>
                </span>
              </button>
            <% end %>
          </div>
        <% end %>
        <% if library_songs.empty? %>
          <p class="text-xs text-outline px-3 py-2 font-body">No songs in library yet.</p>
        <% end %>
        <p data-song-search-target="empty" hidden class="text-xs text-outline px-3 py-2 font-body">No matches.</p>
      </div>

      <%# Import/Paste — only shown when search has no matches %>
      <div data-song-search-target="importSection" hidden class="space-y-3 mt-2">
        <div class="flex items-center gap-3 p-3 bg-surface-container border border-dashed border-outline-variant/40 rounded-lg">
          <span class="material-symbols-outlined text-outline/60">info</span>
          <p class="text-xs text-on-surface-variant font-body flex-1">Not in library — import from web?</p>
          <%= form_with url: import_songs_path, method: :post, data: { turbo: false }, class: "flex-shrink-0" do |f| %>
            <%= hidden_field_tag :deck_id, @deck.id %>
            <%= f.hidden_field :title, data: { "song-search-target": "importTitle" } %>
            <%= f.submit "Import", class: "h-8 px-4 bg-tertiary text-on-tertiary rounded-lg font-medium hover:bg-tertiary-container transition-colors cursor-pointer text-xs font-label" %>
          <% end %>
        </div>

        <details class="group/paste">
          <summary class="cursor-pointer text-primary font-medium flex items-center gap-2 select-none hover:underline decoration-outline-variant text-xs font-label">
            <span class="material-symbols-outlined text-[16px] transition-transform group-open/paste:rotate-180">expand_more</span>
            Paste lyrics manually instead
          </summary>
          <div class="mt-3 space-y-2">
            <%= form_with url: import_songs_path, method: :post, data: { turbo: false }, class: "space-y-2" do |f| %>
              <%= hidden_field_tag :deck_id, @deck.id %>
              <%= f.text_field :title,
                    placeholder: "Song title",
                    data: { "song-search-target": "importTitle" },
                    class: "w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary text-on-surface placeholder:text-on-surface-variant/40 font-body" %>
              <%= f.text_area :raw_lyrics, placeholder: "Paste raw lyrics here...", rows: 4,
                    class: "w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary text-on-surface placeholder:text-on-surface-variant/40 font-body" %>
              <%= f.submit "Import Pasted Lyrics", class: "w-full bg-gradient-to-r from-primary to-primary-container text-on-primary text-sm px-3 py-2 rounded-lg font-medium hover:opacity-95 cursor-pointer" %>
            <% end %>
          </div>
        </details>
      </div>

      <%= link_to songs_path, class: "w-full flex items-center justify-center gap-1.5 text-xs text-primary border border-outline-variant/40 hover:bg-surface-container-high rounded-lg px-3 py-2 transition-colors font-label mt-3" do %>
        <span class="material-symbols-outlined text-[14px]">library_music</span>
        Browse full song library
      <% end %>
    </section>
  </aside>

  <%# MIDDLE — Slide preview %>
  <main class="lg:col-span-6 p-8 overflow-y-auto lg:max-h-[calc(100vh-144px)] bg-surface" id="slide_preview_section">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="font-headline text-2xl text-on-surface">Slide Preview</h2>
        <p class="text-sm text-on-surface-variant font-body">Approximate representation</p>
      </div>
    </div>
    <%= render "decks/slide_preview", deck: @deck %>
  </main>

  <%# RIGHT — Theme %>
  <aside class="lg:col-span-3 bg-surface-container-low border-l border-outline-variant/10 p-6 flex flex-col gap-8 overflow-y-auto lg:max-h-[calc(100vh-144px)]" id="theme_section">
    <section class="space-y-6">
      <h3 class="font-headline text-xl text-on-surface">Theme</h3>

      <%= turbo_stream_from "deck_export_#{@deck.id}" %>
      <%= turbo_stream_from "deck_themes_#{@deck.id}" %>

      <% if @deck.theme.present? %>
        <%= render "themes/applied_theme", theme: @deck.theme, deck: @deck %>
      <% else %>
        <%= render "themes/form", deck: @deck %>
      <% end %>

      <%# AI suggestions %>
      <div class="pt-6 border-t border-outline-variant/20">
        <%= button_to suggest_deck_themes_path(@deck), method: :post,
            class: "w-full py-2 px-4 rounded-lg border border-primary text-primary text-sm flex items-center justify-center gap-2 hover:bg-primary hover:text-on-primary transition-colors cursor-pointer font-label" do %>
          <span class="material-symbols-outlined text-[16px]">auto_awesome</span>
          <span>Get Suggestions</span>
        <% end %>
        <p class="text-[10px] text-center mt-3 text-outline font-body italic px-4">Claude suggests 5 themes with worship photography.</p>
      </div>

      <div id="theme_suggestions"></div>
    </section>

    <%# Display Settings %>
    <section class="space-y-4 pt-6 border-t border-outline-variant/20">
      <h3 class="font-headline text-xl text-on-surface">Display</h3>

      <%= form_with url: deck_path(@deck), method: :patch, scope: :deck, class: "space-y-4" do |f| %>
        <%# Show Pinyin %>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-on-surface font-body">Show Pinyin</p>
            <p class="text-xs text-on-surface-variant font-body">Tone-marked pronunciation above characters</p>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <%= f.check_box :show_pinyin,
                { checked: @deck.show_pinyin,
                  class: "sr-only peer",
                  id: "show_pinyin_toggle" },
                "1", "0" %>
            <div class="w-11 h-6 bg-surface-container-highest rounded-full peer
                        peer-checked:bg-primary peer-checked:after:translate-x-full
                        after:content-[''] after:absolute after:top-[2px] after:left-[2px]
                        after:bg-white after:rounded-full after:h-5 after:w-5
                        after:transition-all transition-colors"></div>
          </label>
        </div>

        <%# Lines per Slide %>
        <div>
          <label class="block text-sm font-medium text-on-surface font-body mb-1">Lines per Slide</label>
          <p class="text-xs text-on-surface-variant font-body mb-2">Sections with more lines split into multiple slides</p>
          <%= f.select :lines_per_slide,
              options_for_select((1..8).map { |n| ["#{n} line#{'s' if n > 1}", n] }, @deck.lines_per_slide),
              {},
              class: "w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary text-on-surface font-body" %>
        </div>

        <%= f.submit "Save Display Settings",
            class: "w-full border border-primary text-primary text-sm px-4 py-2 rounded-lg font-label hover:bg-primary hover:text-on-primary transition-colors cursor-pointer" %>
      <% end %>
    </section>
  </aside>

</div>
