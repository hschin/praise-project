<% content_for :main_class, 'w-full px-6 py-8' %>
<div>

  <%# Header — full width %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @deck.title %></h1>
      <p class="text-sm text-gray-500 mt-1"><%= @deck.date.strftime("%A, %d %B %Y") %></p>
      <% if @deck.notes.present? %>
        <p class="text-sm text-gray-600 mt-1"><%= @deck.notes %></p>
      <% end %>
    </div>
    <div class="flex gap-3 items-center">
      <%= button_to "Export PPTX", export_deck_path(@deck), method: :post,
          class: "bg-indigo-600 text-white text-sm px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
      <%= link_to "Edit deck", edit_deck_path(@deck), class: "text-sm text-indigo-600 hover:underline" %>
      <%= link_to "Back", decks_path, class: "text-sm text-gray-500 hover:underline" %>
    </div>
  </div>

  <%# 3-column editor layout %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 items-start">

    <%# LEFT — Song & slide arrangement %>
    <div class="md:col-span-1 lg:col-span-3 space-y-4">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400">Arrangement</h2>

      <%# Sortable song list %>
      <div data-controller="sortable"
           data-sortable-url-value="<%= reorder_deck_deck_song_path(@deck, ':id') %>"
           class="space-y-3">
        <% if @deck.deck_songs.any? %>
          <% @deck.deck_songs.each do |deck_song| %>
            <%= render "deck_songs/song_block", deck: @deck, deck_song: deck_song %>
          <% end %>
        <% else %>
          <p class="text-gray-400 text-sm">No songs added yet.</p>
        <% end %>
      </div>

      <%# Add Song form %>
      <div class="pt-3 border-t border-gray-100">
        <p class="text-xs font-semibold text-gray-500 mb-2">Add a song</p>
        <%= form_with url: deck_deck_songs_path(@deck), class: "space-y-2" do |f| %>
          <%= f.select :song_id,
              Song.order(:title).map { |s| [s.title, s.id] },
              { include_blank: "Select a song..." },
              class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
          <%= f.submit "Add to deck", class: "w-full bg-indigo-600 text-white text-sm px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <%# MIDDLE — Slide preview %>
    <div class="md:col-span-1 lg:col-span-6" id="slide_preview_section">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-4">Slide Preview <span class="normal-case font-normal text-gray-300 ml-1">— approximate</span></h2>
      <% if @deck.deck_songs.any? %>
        <div class="space-y-6">
          <% @deck.deck_songs.each do |deck_song| %>
            <% slides = (deck_song.arrangement || []).filter_map { |id| Lyric.find_by(id: id) } %>
            <% next if slides.empty? %>
            <div>
              <p class="text-xs text-gray-400 mb-2"><%= deck_song.song.title %></p>
              <div class="grid grid-cols-2 gap-3">
                <% slides.each do |lyric| %>
                  <div class="slide-preview rounded-lg shadow overflow-hidden relative w-full"
                       style="aspect-ratio: 16/9; container-type: inline-size; background-color: <%= @deck.theme&.background_color.presence || '#1a1a2e' %>;<%= @deck.theme&.background_image&.attached? ? "background-image: url('#{url_for(@deck.theme.background_image)}'); background-size: cover; background-position: center;" : "" %>">
                    <div class="absolute inset-0 flex items-center justify-center" style="padding: 4cqw;">
                      <div class="text-center" style="color: <%= @deck.theme&.text_color.presence || '#ffffff' %>; font-size: 3.5cqw; line-height: 1.8;">
                        <% lyric.content.to_s.split("\n").each_with_index do |line, li| %>
                          <% pinyin_line = lyric.pinyin.to_s.split("\n")[li] || "" %>
                          <div>
                            <% chars = line.chars %>
                            <% tokens = pinyin_line.split(" ") %>
                            <% pi = 0 %>
                            <% chars.each do |char| %>
                              <% if char.match?(/\p{Han}/) %>
                                <ruby><%= char %><rt style="font-size:0.6em"><%= tokens[pi] %></rt></ruby><% pi += 1 %>
                              <% else %><%= char %><% end %>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                    <div class="absolute bottom-0 right-0 opacity-40" style="font-size: 1.8cqw; padding: 1cqw 2cqw; color: <%= @deck.theme&.text_color.presence || '#ffffff' %>;">
                      <%= lyric.section_type %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex items-center justify-center h-48 rounded-lg border-2 border-dashed border-gray-200">
          <p class="text-sm text-gray-400">Add songs to see slide previews.</p>
        </div>
      <% end %>
    </div>

    <%# RIGHT — Theme %>
    <div class="md:col-span-2 lg:col-span-3" id="theme_section">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-4">Theme</h2>

      <%= turbo_stream_from "deck_themes_#{@deck.id}" %>

      <% if @deck.theme.present? %>
        <%= render "themes/applied_theme", theme: @deck.theme, deck: @deck %>
        <details class="mt-4">
          <summary class="text-xs text-indigo-500 cursor-pointer hover:underline">Change theme</summary>
          <div class="mt-3">
            <%= render "themes/form", deck: @deck %>
          </div>
        </details>
      <% else %>
        <%= render "themes/form", deck: @deck %>
      <% end %>

      <%# AI suggestions %>
      <div class="mt-4 pt-4 border-t border-gray-100">
        <%= button_to "✦ Get AI Suggestions",
            suggest_deck_themes_path(@deck),
            method: :post,
            class: "w-full text-sm bg-white border border-indigo-300 text-indigo-600 px-3 py-2 rounded hover:bg-indigo-50 cursor-pointer" %>
        <p class="text-xs text-gray-400 mt-1 text-center">Claude suggests 5 themes with worship photography.</p>
      </div>

      <div id="theme_suggestions" class="mt-4"></div>
    </div>

  </div>
</div>
