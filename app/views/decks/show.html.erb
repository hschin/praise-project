<div class="max-w-3xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @deck.title %></h1>
      <p class="text-sm text-gray-500 mt-1"><%= @deck.date.strftime("%A, %d %B %Y") %></p>
    </div>
    <div class="flex gap-3">
      <%= button_to "Export PPTX", export_deck_path(@deck), method: :post,
          class: "bg-indigo-600 text-white text-sm px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
      <%= link_to "Edit deck", edit_deck_path(@deck), class: "text-sm text-indigo-600 hover:underline" %>
      <%= link_to "Back", decks_path, class: "text-sm text-gray-500 hover:underline" %>
    </div>
  </div>

  <% if @deck.notes.present? %>
    <p class="text-sm text-gray-600 mb-6"><%= @deck.notes %></p>
  <% end %>

  <%# Song list — sortable by drag %>
  <div data-controller="sortable"
       data-sortable-url-value="<%= reorder_deck_deck_song_path(@deck, ':id') %>"
       class="space-y-3 mb-8">
    <% if @deck.deck_songs.any? %>
      <% @deck.deck_songs.each do |deck_song| %>
        <%= render "deck_songs/song_block", deck: @deck, deck_song: deck_song %>
      <% end %>
    <% else %>
      <p class="text-gray-400 text-sm">No songs added yet.</p>
    <% end %>
  </div>

  <%# Add Song form %>
  <div class="border-t pt-6 mb-8">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">Add a Song</h2>
    <%= form_with url: deck_deck_songs_path(@deck), class: "flex gap-3" do |f| %>
      <%= f.select :song_id,
          Song.order(:title).map { |s| [s.title, s.id] },
          { include_blank: "Select a song..." },
          class: "flex-1 border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      <%= f.submit "Add", class: "bg-indigo-600 text-white text-sm px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
    <% end %>
  </div>

  <%# Theme section %>
  <div class="border-t pt-6 mb-8" id="theme_section">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">Theme</h2>

    <% if @deck.theme.present? %>
      <%= render "themes/applied_theme", theme: @deck.theme, deck: @deck %>
      <details class="mt-4">
        <summary class="text-xs text-indigo-500 cursor-pointer hover:underline">Change theme</summary>
        <div class="mt-3">
          <%= render "themes/form", deck: @deck %>
        </div>
      </details>
    <% else %>
      <%= render "themes/form", deck: @deck %>
    <% end %>

    <%# AI suggestion row — populated by Plan 05 %>
    <%= turbo_stream_from "deck_themes_#{@deck.id}" %>
    <div id="theme_suggestions" class="mt-4"></div>
  </div>

  <%# Slide preview section %>
  <div class="border-t pt-6" id="slide_preview_section">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">Slide Preview</h2>
    <% if @deck.deck_songs.any? %>
      <div class="flex flex-wrap gap-3">
        <% @deck.deck_songs.each do |deck_song| %>
          <% (deck_song.arrangement || []).each do |lyric_id| %>
            <% lyric = Lyric.find_by(id: lyric_id) %>
            <% next if lyric.nil? %>
            <div class="slide-preview w-48 rounded shadow-md overflow-hidden relative"
                 style="aspect-ratio: 16/9; background-color: <%= @deck.theme&.background_color || '#000000' %>;">
              <div class="absolute inset-0 flex items-center justify-center p-2">
                <div class="text-center" style="color: <%= @deck.theme&.text_color || '#ffffff' %>; font-size: 0.55rem; line-height: 1.4;">
                  <% lyric.content.to_s.split("\n").each_with_index do |line, li| %>
                    <% pinyin_line = lyric.pinyin.to_s.split("\n")[li] || "" %>
                    <div>
                      <% chars = line.chars %>
                      <% tokens = pinyin_line.split(" ") %>
                      <% pi = 0 %>
                      <% chars.each do |char| %>
                        <% if char.match?(/\p{Han}/) %>
                          <ruby><%= char %><rt style="font-size:0.45em"><%= tokens[pi] %></rt></ruby><% pi += 1 %>
                        <% else %><%= char %><% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
      <p class="text-xs text-gray-400 mt-2">Approximate Preview</p>
    <% else %>
      <p class="text-sm text-gray-400">Add songs to see slide previews.</p>
    <% end %>
  </div>
</div>
