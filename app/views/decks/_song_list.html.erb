<%# locals: (deck:) %>
<div data-controller="song-order"
     data-song-order-url-value="<%= reorder_deck_deck_song_path(deck, ':id') %>"
     data-song-order-param-value="order"
     data-song-order-handle-value="[data-song-drag-handle]"
     class="space-y-3">
  <% if deck.deck_songs.any? %>
    <% deck.deck_songs.each do |deck_song| %>
      <%= render "deck_songs/song_block", deck: deck, deck_song: deck_song %>
    <% end %>
  <% else %>
    <div class="text-center py-8">
      <span class="material-symbols-outlined text-3xl text-outline/40">music_note</span>
      <p class="text-sm text-on-surface-variant font-body mt-2">Your arrangement will appear here. Add a song from the panel below.</p>
    </div>
  <% end %>
</div>
