<% state ||= :idle %>
<% token ||= nil %>
<% error_message ||= nil %>

<div id="export_button_<%= deck.id %>">
  <% if state == :generating %>
    <button disabled
      class="flex items-center gap-2 bg-primary/60 text-on-primary text-sm px-4 py-2 rounded-lg cursor-not-allowed font-label">
      <span class="animate-spin inline-block w-4 h-4 border-2 border-on-primary border-t-transparent rounded-full"></span>
      Generating…
    </button>
  <% elsif state == :ready %>
    <div class="flex items-center gap-3">
      <%= button_to "Re-export", export_deck_path(deck), method: :post,
          class: "text-xs text-on-surface-variant/60 hover:text-on-surface-variant hover:underline bg-transparent border-none cursor-pointer font-body p-0" %>
      <%= link_to download_export_deck_path(deck, token: token),
          class: "flex items-center gap-2 bg-primary text-on-primary text-sm px-4 py-2 rounded-lg hover:opacity-90 active:scale-[0.98] transition-all font-label" do %>
        <span class="material-symbols-outlined text-[16px]">download</span>
        Download PPTX
      <% end %>
    </div>
  <% elsif state == :error %>
    <%= button_to export_deck_path(deck), method: :post,
        class: "flex items-center gap-2 bg-primary text-on-primary text-sm px-4 py-2 rounded-lg hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer font-label" do %>
      <span class="material-symbols-outlined text-[16px]">file_download</span>
      Export PPTX
    <% end %>
    <p class="text-xs text-error mt-1 font-body"><%= error_message.presence || "Export failed — click to try again." %></p>
  <% else %>
    <%# :idle %>
    <%= button_to export_deck_path(deck), method: :post,
        class: "flex items-center gap-2 bg-primary text-on-primary text-sm px-4 py-2 rounded-lg hover:opacity-90 active:scale-[0.98] transition-all cursor-pointer font-label" do %>
      <span class="material-symbols-outlined text-[16px]">file_download</span>
      Export PPTX
    <% end %>
  <% end %>
</div>
