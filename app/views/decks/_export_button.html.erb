<% state ||= :idle %>
<% token ||= nil %>
<% error_message ||= nil %>

<div id="export_button_<%= deck.id %>">
  <% if state == :generating %>
    <button disabled
      class="bg-surface-container-high text-on-surface-variant text-sm px-4 py-2 rounded-lg cursor-not-allowed flex items-center gap-2 font-body">
      <span class="animate-spin inline-block w-3 h-3 border-2 border-primary border-t-transparent rounded-full"></span>
      Generating...
    </button>
  <% elsif state == :ready %>
    <div>
      <%= link_to download_export_deck_path(deck, token: token),
          class: "bg-tertiary text-on-tertiary text-sm px-4 py-2 rounded-lg hover:bg-tertiary-container inline-flex items-center gap-2 font-body" do %>
        <span class="material-symbols-outlined text-base">check_circle</span>
        Download .pptx
      <% end %>
      <div class="mt-1">
        <%= button_to "Re-export", export_deck_path(deck), method: :post,
            class: "text-xs text-on-surface-variant/60 hover:text-on-surface-variant hover:underline bg-transparent border-none cursor-pointer font-body" %>
      </div>
    </div>
  <% elsif state == :error %>
    <%= button_to export_deck_path(deck), method: :post,
        class: "bg-gradient-to-r from-primary to-primary-container text-on-primary text-sm px-4 py-2 rounded-lg hover:opacity-95 cursor-pointer flex items-center gap-2 font-body" do %>
      <span class="material-symbols-outlined text-base">download</span>
      Export PPTX
    <% end %>
    <p class="text-sm text-error mt-1 font-body"><%= error_message.presence || "Export failed — click to try again." %></p>
  <% else %>
    <%# :idle — default %>
    <%= button_to export_deck_path(deck), method: :post,
        class: "flex items-center gap-2 bg-surface-container-highest text-on-surface px-6 py-2.5 rounded-xl hover:bg-surface-dim transition-colors font-medium cursor-pointer font-body" do %>
      <span class="material-symbols-outlined text-base">file_download</span>
      Export to PPTX
    <% end %>
  <% end %>
</div>
