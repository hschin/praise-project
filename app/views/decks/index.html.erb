<% if @song %>
  <div class="mb-10 rounded-2xl bg-primary/8 border border-primary/20 px-6 py-5 flex items-center justify-between gap-4">
    <div class="flex items-center gap-4 min-w-0">
      <div class="w-10 h-10 rounded-full bg-primary/15 flex items-center justify-center flex-shrink-0">
        <span class="material-symbols-outlined text-primary text-[20px]">library_music</span>
      </div>
      <div class="min-w-0">
        <p class="text-xs font-label uppercase tracking-widest text-primary mb-0.5"><%= t("decks.adding_label") %></p>
        <p class="text-base font-medium text-on-surface font-body truncate"><%= @song.title %><% if @song.english_title.present? %><span class="text-on-surface-variant font-normal"> · <%= @song.english_title %></span><% end %></p>
      </div>
    </div>
    <%= link_to song_path(@song), class: "inline-flex items-center gap-1 text-xs text-on-surface-variant hover:text-primary transition-colors font-body flex-shrink-0" do %>
      <span class="material-symbols-outlined text-[14px]">close</span>
      <%= t("decks.cancel") %>
    <% end %>
  </div>
  <div class="mb-8">
    <h1 class="font-headline text-4xl md:text-5xl text-on-surface mb-2"><%= t("decks.pick_title") %></h1>
    <p class="text-on-surface-variant font-body"><%= t("decks.pick_subtitle") %></p>
  </div>
<% else %>
  <div class="mb-12">
    <h1 class="font-headline text-4xl md:text-5xl text-on-surface mb-2"><%= t("decks.title") %></h1>
    <p class="text-on-surface-variant font-body"><%= t("decks.subtitle") %></p>
  </div>
<% end %>

<% if @decks.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <% @decks.each do |deck| %>
      <% if @song %>
        <%# Pick mode: whole card is a POST form to add song to this deck %>
        <%= form_with url: deck_deck_songs_path(deck), method: :post, class: "group relative flex flex-col bg-surface-container-lowest rounded-xl overflow-hidden transition-all duration-300 hover:-translate-y-1 cursor-pointer", style: "box-shadow: 0 10px 40px rgba(31,27,23,0.04);" do |f| %>
          <%= f.hidden_field :song_id, value: @song.id %>
          <button type="submit" class="contents">
            <div class="aspect-video w-full overflow-hidden relative
                        <%= deck.theme&.unsplash_url.present? ? 'bg-surface-container' : deck.theme&.background_color.present? ? '' : 'bg-gradient-to-br from-surface-container to-surface-container-high' %>"
                 <%= deck.theme&.unsplash_url.present? ? "style=background-image:url('#{deck.theme.unsplash_url}');background-size:cover;background-position:center;".html_safe : deck.theme&.background_color.present? ? "style=background-color:#{deck.theme.background_color};".html_safe : "" %>>
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/10">
                <span class="bg-primary text-on-primary rounded-full px-4 py-1.5 text-sm font-medium font-body flex items-center gap-1.5">
                  <span class="material-symbols-outlined text-[16px]">add</span>
                  <%= t("decks.add_here") %>
                </span>
              </div>
            </div>
            <div class="p-6 flex flex-col gap-1 flex-1 text-left">
              <div class="flex justify-between items-start gap-2">
                <h3 class="font-headline text-xl text-on-surface group-hover:text-primary transition-colors leading-snug"><%= deck.title %></h3>
                <span class="text-xs font-medium bg-surface-container-high text-on-surface-variant px-2 py-1 rounded flex-shrink-0"><%= t("decks.songs_count", count: deck.deck_songs.count) %></span>
              </div>
              <p class="text-sm text-on-surface-variant font-body"><%= deck.date.strftime("%A %-d %B") %></p>
            </div>
          </button>
        <% end %>
      <% else %>
        <%# Normal mode %>
        <div class="group relative flex flex-col bg-surface-container-lowest rounded-xl overflow-hidden transition-all duration-300 hover:-translate-y-1"
             style="box-shadow: 0 10px 40px rgba(31,27,23,0.04);">
          <%= link_to deck_path(deck), class: "block" do %>
            <div class="aspect-video w-full overflow-hidden relative
                        <%- if deck.theme&.unsplash_url.present? %>bg-surface-container
                        <%- elsif deck.theme&.background_color.present? %>
                        <%- else %>bg-gradient-to-br from-surface-container to-surface-container-high<% end %>"
                 <%- if deck.theme&.unsplash_url.present? %>style="background-image: url('<%= deck.theme.unsplash_url %>'); background-size: cover; background-position: center;"
                 <%- elsif deck.theme&.background_color.present? %>style="background-color: <%= deck.theme.background_color %>;"<% end %>>
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            </div>
          <% end %>
          <div class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity z-10">
            <%= button_to deck_path(deck), method: :delete,
                  data: { turbo_confirm: "Delete \"#{deck.title}\"?" },
                  class: "bg-white/90 backdrop-blur-sm hover:bg-error hover:text-white text-on-surface p-2 rounded-lg transition-all duration-200 cursor-pointer border-0" do %>
              <span class="material-symbols-outlined text-base">delete</span>
            <% end %>
          </div>
          <%= link_to deck_path(deck), class: "p-6 flex flex-col gap-1 flex-1" do %>
            <div class="flex justify-between items-start gap-2">
              <h3 class="font-headline text-xl text-on-surface group-hover:text-primary transition-colors leading-snug"><%= deck.title %></h3>
              <span class="text-xs font-medium bg-surface-container-high text-on-surface-variant px-2 py-1 rounded flex-shrink-0"><%= t("decks.songs_count", count: deck.deck_songs.count) %></span>
            </div>
            <p class="text-sm text-on-surface-variant font-body"><%= deck.date.strftime("%A %-d %B") %></p>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%# Dashed "Create New Deck" card — hidden in pick mode %>
    <% unless @song %>
      <%= button_to quick_create_decks_path, method: :post,
            class: "group cursor-pointer flex flex-col border-2 border-dashed border-outline-variant/40 rounded-xl hover:border-primary/40 hover:bg-surface-container-low transition-all duration-300 w-full bg-transparent overflow-hidden" do %>
        <div class="aspect-video w-full flex items-center justify-center bg-surface-container group-hover:bg-surface-container-high transition-colors">
          <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center group-hover:bg-primary group-hover:text-on-primary transition-colors">
            <span class="material-symbols-outlined">add</span>
          </div>
        </div>
        <div class="p-6">
          <span class="font-headline text-xl text-on-surface-variant group-hover:text-primary transition-colors"><%= t("decks.create_new") %></span>
          <p class="text-sm text-on-surface-variant/0 mt-1 font-body select-none">—</p>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center py-24 text-center max-w-2xl mx-auto">
    <div class="w-24 h-24 bg-surface-container-low rounded-full flex items-center justify-center mb-8">
      <span class="material-symbols-outlined text-4xl text-outline">auto_awesome_motion</span>
    </div>
    <h2 class="font-headline text-3xl mb-6 text-on-surface"><%= t("decks.empty_title") %></h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <div class="space-y-3">
        <span class="w-8 h-8 rounded-full bg-primary text-on-primary flex items-center justify-center mx-auto text-xs font-bold font-label">1</span>
        <p class="text-sm font-semibold text-on-surface font-body"><%= t("decks.empty_step1_title") %></p>
        <p class="text-xs text-on-surface-variant font-body"><%= t("decks.empty_step1_desc") %></p>
      </div>
      <div class="space-y-3">
        <span class="w-8 h-8 rounded-full bg-primary text-on-primary flex items-center justify-center mx-auto text-xs font-bold font-label">2</span>
        <p class="text-sm font-semibold text-on-surface font-body"><%= t("decks.empty_step2_title") %></p>
        <p class="text-xs text-on-surface-variant font-body"><%= t("decks.empty_step2_desc") %></p>
      </div>
      <div class="space-y-3">
        <span class="w-8 h-8 rounded-full bg-primary text-on-primary flex items-center justify-center mx-auto text-xs font-bold font-label">3</span>
        <p class="text-sm font-semibold text-on-surface font-body"><%= t("decks.empty_step3_title") %></p>
        <p class="text-xs text-on-surface-variant font-body"><%= t("decks.empty_step3_desc") %></p>
      </div>
    </div>
    <%= button_to t("nav.new_deck"), quick_create_decks_path, method: :post,
          class: "bg-gradient-to-r from-primary to-primary-container text-on-primary px-8 py-4 rounded-xl font-medium shadow-sm hover:shadow-md hover:opacity-95 active:scale-[0.98] transition-all duration-200 cursor-pointer" %>
  </div>
<% end %>
