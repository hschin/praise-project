<div class="max-w-4xl mx-auto px-4 py-8 space-y-8">

  <div class="flex items-center gap-4">
    <%= link_to admin_decks_path, class: "text-on-surface-variant hover:text-primary transition-colors" do %>
      <span class="material-symbols-outlined text-[20px]">arrow_back</span>
    <% end %>
    <div>
      <h1 class="text-2xl font-bold text-on-surface"><%= @deck.title %></h1>
      <p class="text-sm text-on-surface-variant">
        <%= @deck.user.email %> &middot;
        <%= @deck.date&.strftime("%A, %d %B %Y") %> &middot;
        Created <%= @deck.created_at.strftime("%d %b %Y %H:%M") %>
      </p>
    </div>
    <%= link_to "Open deck", deck_path(@deck), class: "ml-auto text-xs text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/5 transition-colors" %>
  </div>

  <%# Settings snapshot %>
  <div class="bg-surface-container rounded-xl p-5 space-y-3">
    <h2 class="text-sm font-semibold text-on-surface">Settings</h2>
    <dl class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
      <div>
        <dt class="text-xs text-on-surface-variant">Show Pinyin</dt>
        <dd class="text-on-surface font-medium"><%= @deck.show_pinyin ? "Yes" : "No" %></dd>
      </div>
      <div>
        <dt class="text-xs text-on-surface-variant">Lines per slide</dt>
        <dd class="text-on-surface font-medium"><%= @deck.lines_per_slide %></dd>
      </div>
      <div>
        <dt class="text-xs text-on-surface-variant">Notes</dt>
        <dd class="text-on-surface font-medium"><%= @deck.notes.presence || "—" %></dd>
      </div>
      <div>
        <dt class="text-xs text-on-surface-variant">Deck ID</dt>
        <dd class="text-on-surface font-mono text-xs"><%= @deck.id %></dd>
      </div>
    </dl>
  </div>

  <%# Songs in deck %>
  <div class="bg-surface-container rounded-xl p-5 space-y-3">
    <h2 class="text-sm font-semibold text-on-surface">Songs (<%= @deck.deck_songs.size %>)</h2>
    <% if @deck.deck_songs.any? %>
      <ul class="divide-y divide-outline-variant/20">
        <% @deck.deck_songs.each do |ds| %>
          <li class="py-3 flex items-start justify-between gap-4">
            <div class="min-w-0 space-y-0.5">
              <p class="text-sm font-medium text-on-surface"><%= ds.song.title %></p>
              <p class="text-xs text-on-surface-variant"><%= ds.song.artist %></p>
              <% if ds.key.present? %>
                <p class="text-xs text-on-surface-variant">Key: <%= ds.key %></p>
              <% end %>
            </div>
            <div class="text-right shrink-0 space-y-0.5">
              <p class="text-xs text-on-surface-variant">Position <%= ds.position %></p>
              <p class="text-xs text-on-surface-variant"><%= ds.song.lyrics.count %> sections</p>
              <%= link_to "View song", song_path(ds.song), class: "text-xs text-primary hover:underline" %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-on-surface-variant">No songs in this deck.</p>
    <% end %>
  </div>

  <%# Export history %>
  <div class="bg-surface-container rounded-xl p-5 space-y-3">
    <h2 class="text-sm font-semibold text-on-surface">Export history (<%= @exports.size %>)</h2>
    <% if @exports.any? %>
      <ul class="divide-y divide-outline-variant/20">
        <% @exports.each do |exp| %>
          <li class="py-2.5 flex items-center justify-between gap-4">
            <span class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full <%= exp.generated? ? 'bg-primary/10 text-primary' : 'bg-tertiary/10 text-tertiary' %>">
              <span class="material-symbols-outlined text-[14px]"><%= exp.generated? ? "file_download" : "check_circle" %></span>
              <%= exp.event.capitalize %>
            </span>
            <span class="text-xs text-on-surface-variant"><%= exp.created_at.strftime("%d %b %Y %H:%M") %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-on-surface-variant">No exports for this deck.</p>
    <% end %>
  </div>

</div>
