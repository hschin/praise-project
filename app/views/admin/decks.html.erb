<div class="max-w-6xl mx-auto px-4 py-8 space-y-6">
  <div class="flex items-center gap-4">
    <%= link_to admin_path, class: "text-on-surface-variant hover:text-primary transition-colors" do %>
      <span class="material-symbols-outlined text-[20px]">arrow_back</span>
    <% end %>
    <h1 class="text-2xl font-bold text-on-surface">All Decks</h1>
    <span class="text-sm text-on-surface-variant ml-auto"><%= @decks.count %> total</span>
  </div>

  <div class="bg-surface-container rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs text-on-surface-variant border-b border-outline-variant/30 bg-surface-container-high">
          <th class="px-4 py-3 font-medium">Deck</th>
          <th class="px-4 py-3 font-medium">User</th>
          <th class="px-4 py-3 font-medium">Date</th>
          <th class="px-4 py-3 font-medium text-center">Songs</th>
          <th class="px-4 py-3 font-medium text-center">Generated</th>
          <th class="px-4 py-3 font-medium text-center">Downloaded</th>
          <th class="px-4 py-3 font-medium text-right">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-outline-variant/20">
        <% @decks.each do |deck| %>
          <tr class="hover:bg-surface-container-high transition-colors">
            <td class="px-4 py-3 font-medium"><%= link_to deck.title, admin_deck_path(deck), class: "text-on-surface hover:underline" %></td>
            <td class="px-4 py-3 text-on-surface-variant text-xs"><%= deck.user.email %></td>
            <td class="px-4 py-3 text-on-surface-variant text-xs"><%= deck.date&.strftime("%d %b %Y") %></td>
            <td class="px-4 py-3 text-center text-on-surface-variant"><%= deck.deck_songs.size %></td>
            <td class="px-4 py-3 text-center text-on-surface-variant"><%= deck.exports.count(&:generated?) %></td>
            <td class="px-4 py-3 text-center text-on-surface-variant"><%= deck.exports.count(&:downloaded?) %></td>
            <td class="px-4 py-3 text-right text-on-surface-variant text-xs"><%= deck.created_at.strftime("%d %b %Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
